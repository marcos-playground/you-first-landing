---
// Hero section — dramatic, architectural
---

<section class="relative min-h-screen flex items-end pb-20 lg:pb-28 overflow-hidden">
  <!-- Background: deep charcoal with construction texture -->
  <div class="absolute inset-0 bg-charcoal-dark">
    <!-- Gradient mesh overlay -->
    <div class="absolute inset-0 opacity-60" style="background: radial-gradient(ellipse at 20% 50%, rgba(232,97,26,0.12) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(232,97,26,0.06) 0%, transparent 50%);"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 80px 80px;"></div>
  </div>

  <!-- Diagonal accent line -->
  <div class="absolute top-0 right-0 w-1/2 h-full opacity-10">
    <svg class="w-full h-full" viewBox="0 0 600 800" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="0" y1="800" x2="600" y2="100" stroke="#E8611A" stroke-width="1.5" />
      <line x1="100" y1="800" x2="600" y2="200" stroke="#E8611A" stroke-width="0.8" />
      <line x1="200" y1="800" x2="600" y2="300" stroke="#E8611A" stroke-width="0.4" />
    </svg>
  </div>

  <!-- Roofline decorative element -->
  <div class="absolute top-[15%] right-[8%] opacity-[0.06] hidden lg:block">
    <svg width="300" height="200" viewBox="0 0 300 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M150 10L290 120H270L150 30L30 120H10L150 10Z" stroke="#E8611A" stroke-width="2"/>
      <path d="M230 120V190H200V150H170V190H70V120" stroke="#E8611A" stroke-width="1.5"/>
    </svg>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 w-full">
    <div class="max-w-4xl">
      <!-- Tagline -->
      <div class="mb-8 overflow-hidden">
        <p
          class="font-heading text-sm lg:text-base font-medium tracking-[0.3em] uppercase text-ember opacity-0"
          style="animation: reveal-up 0.8s cubic-bezier(0.16,1,0.3,1) 0.3s forwards;"
        >
          Custom Home Builders
        </p>
      </div>

      <!-- Main headline -->
      <h1 class="mb-8">
        <span
          class="block font-display text-5xl sm:text-6xl lg:text-8xl text-white leading-[0.95] opacity-0"
          style="animation: reveal-up 0.9s cubic-bezier(0.16,1,0.3,1) 0.5s forwards;"
        >
          We Build
        </span>
        <span
          class="block font-display text-5xl sm:text-6xl lg:text-8xl text-white leading-[0.95] mt-2 opacity-0"
          style="animation: reveal-up 0.9s cubic-bezier(0.16,1,0.3,1) 0.65s forwards;"
        >
          What <em class="text-ember not-italic">Matters</em>
        </span>
        <span
          class="block font-display text-5xl sm:text-6xl lg:text-8xl text-white leading-[0.95] mt-2 opacity-0"
          style="animation: reveal-up 0.9s cubic-bezier(0.16,1,0.3,1) 0.8s forwards;"
        >
          Most.
        </span>
      </h1>

      <!-- Ember accent line -->
      <div
        class="w-24 h-1 bg-ember mb-8 opacity-0"
        style="animation: draw-line 0.8s cubic-bezier(0.16,1,0.3,1) 1.0s forwards; transform-origin: left;"
      ></div>

      <!-- Subtitle -->
      <p
        class="font-body text-lg lg:text-xl text-steel max-w-xl leading-relaxed mb-12 opacity-0"
        style="animation: reveal-up 0.8s cubic-bezier(0.16,1,0.3,1) 1.1s forwards;"
      >
        From custom homes to complete renovations, You First Construction delivers
        craftsmanship that stands the test of time. Your vision, built right.
      </p>

      <!-- CTA Buttons -->
      <div
        class="flex flex-wrap gap-4 opacity-0"
        style="animation: reveal-up 0.8s cubic-bezier(0.16,1,0.3,1) 1.3s forwards;"
      >
        <a href="#contact" class="btn-primary font-heading text-sm font-semibold tracking-wider uppercase px-10 py-4">
          Start Your Project
        </a>
        <a href="#projects" class="btn-outline border-white/30 text-white hover:border-ember hover:text-ember font-heading text-sm font-semibold tracking-wider uppercase px-10 py-4">
          View Our Work
        </a>
      </div>
    </div>

    <!-- Stats bar -->
    <div
      class="mt-20 lg:mt-28 grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-16 border-t border-white/10 pt-10 opacity-0"
      style="animation: fade-in 1s cubic-bezier(0.16,1,0.3,1) 1.6s forwards;"
    >
      <div>
        <span class="block font-display text-3xl lg:text-4xl text-ember">25+</span>
        <span class="font-body text-sm text-steel mt-1 block">Years Experience</span>
      </div>
      <div>
        <span class="block font-display text-3xl lg:text-4xl text-ember">500+</span>
        <span class="font-body text-sm text-steel mt-1 block">Homes Built</span>
      </div>
      <div>
        <span class="block font-display text-3xl lg:text-4xl text-ember">100%</span>
        <span class="font-body text-sm text-steel mt-1 block">Client Satisfaction</span>
      </div>
      <div>
        <span class="block font-display text-3xl lg:text-4xl text-ember">Award</span>
        <span class="font-body text-sm text-steel mt-1 block">Winning Builder</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0"
    style="animation: fade-in 1s cubic-bezier(0.16,1,0.3,1) 2s forwards;"
  >
    <span class="font-heading text-[10px] tracking-[0.3em] uppercase text-steel">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-ember to-transparent"></div>
  </div>
</section>
