---
// Footer component
const currentYear = new Date().getFullYear();
---

<footer class="bg-charcoal-dark border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <!-- Main footer -->
    <div class="py-16 lg:py-20 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <img src="/logo.png" alt="You First Construction" class="h-14 w-auto mb-6 brightness-200 contrast-75" />
        <p class="font-body text-sm text-steel leading-relaxed max-w-xs">
          Premium custom home construction and renovation services.
          Putting you first since day one.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-heading text-xs font-semibold tracking-[0.25em] uppercase text-white mb-6">Services</h4>
        <ul class="space-y-3">
          <li><a href="#services" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">Custom Homes</a></li>
          <li><a href="#services" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">Renovations</a></li>
          <li><a href="#services" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">ADUs</a></li>
          <li><a href="#services" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">Commercial</a></li>
          <li><a href="#services" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">Outdoor Living</a></li>
          <li><a href="#services" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">Consulting</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-heading text-xs font-semibold tracking-[0.25em] uppercase text-white mb-6">Company</h4>
        <ul class="space-y-3">
          <li><a href="#about" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">About Us</a></li>
          <li><a href="#projects" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">Projects</a></li>
          <li><a href="#" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">Testimonials</a></li>
          <li><a href="#" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">Careers</a></li>
          <li><a href="#" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">Blog</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-heading text-xs font-semibold tracking-[0.25em] uppercase text-white mb-6">Contact</h4>
        <ul class="space-y-3">
          <li>
            <a href="tel:+15551234567" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">(555) 123-4567</a>
          </li>
          <li>
            <a href="mailto:info@youfirstconstruction.com" class="font-body text-sm text-steel hover:text-ember transition-colors duration-300">info@youfirstconstruction.com</a>
          </li>
          <li>
            <span class="font-body text-sm text-steel">Mon - Fri: 8AM - 6PM</span>
          </li>
          <li>
            <span class="font-body text-sm text-steel">Sat: 9AM - 2PM</span>
          </li>
        </ul>

        <!-- Social -->
        <div class="flex gap-4 mt-6">
          <a href="#" class="w-9 h-9 rounded-sm bg-white/5 flex items-center justify-center hover:bg-ember transition-colors duration-300 group" aria-label="Facebook">
            <svg class="w-4 h-4 text-steel group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-sm bg-white/5 flex items-center justify-center hover:bg-ember transition-colors duration-300 group" aria-label="Instagram">
            <svg class="w-4 h-4 text-steel group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-sm bg-white/5 flex items-center justify-center hover:bg-ember transition-colors duration-300 group" aria-label="LinkedIn">
            <svg class="w-4 h-4 text-steel group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/5 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-body text-xs text-steel/60">
        &copy; {currentYear} You First Construction Inc. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="#" class="font-body text-xs text-steel/60 hover:text-ember transition-colors duration-300">Privacy Policy</a>
        <a href="#" class="font-body text-xs text-steel/60 hover:text-ember transition-colors duration-300">Terms of Service</a>
        <a href="#" class="font-body text-xs text-steel/60 hover:text-ember transition-colors duration-300">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
