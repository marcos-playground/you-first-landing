---
import Layout from '../../layouts/Layout.astro';
import { siteIcon } from '../../lib/icons';
import { cmsImageFallbackSrc, type AboutPage } from '../../lib/sanityPages';
import { renderPortableText } from '../../lib/portableText';
interface Props {
  page: AboutPage;
  visualEditing?: boolean;
}
const { page, visualEditing = false } = Astro.props;
const journeyHtml = renderPortableText(page.timeline?.content);
---

<Layout
  title={page.seo.title}
  description={page.seo.description}
  currentPage="about"
  visualEditing={visualEditing}
>
  <!-- ===================== HERO ===================== -->
  <section class="site-page-hero site-bg-dark site-texture">
    <div class="site-container">
      <nav class="site-breadcrumb site-reveal" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="site-breadcrumb-sep">/</span>
        <span class="site-breadcrumb-current">About</span>
      </nav>

      <div class="site-about-hero-grid">
        <div class="site-about-hero-text">
          {page.hero.badge && <div class="site-badge site-badge-light site-reveal">{page.hero.badge}</div>}
          <h1 class="site-display site-display-xl site-reveal site-reveal-d1" style="margin-top: 1rem;">
            {page.hero.heading}
          </h1>
          <div class="site-ember-bar site-reveal site-reveal-d2" style="margin-top: 1.25rem;"></div>
          {page.hero.text && <p class="site-text site-reveal site-reveal-d3" style="max-width: 500px; margin-top: 1.25rem;">{page.hero.text}</p>}
        </div>

        <div class="site-about-hero-img site-reveal site-reveal-d2">
          <div class="site-about-hero-img-inner">
            <img
              src={page.hero.image?.asset?.url ?? cmsImageFallbackSrc}
              alt={page.hero.image?.alt ?? ''}
              class:list={['site-cms-image', { 'is-empty': !page.hero.image?.asset?.url }]}
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== MISSION / VISION ===================== -->
  <section class="site-section site-bg-cream site-texture">
    <div class="site-container">
      <div class="site-mv-grid">
        {(page.missionVision ?? []).map((card, i) => (
        <div class={`site-mv-card site-reveal ${i > 0 ? `site-reveal-d${i + 1}` : ''}`}>
          <div class="site-mv-label">
            {card.label && <span class="site-label" style="color: var(--site-ember);">{card.label}</span>}
          </div>
          <h3 class="site-display site-display-md" style="margin-top: 1rem;">
            {card.heading}
          </h3>
          {card.text && <p class="site-text" style="margin-top: 1rem; font-size: 1rem;">{card.text}</p>}
        </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== VALUES ===================== -->
  <section class="site-section">
    <div class="site-container">
      <div style="text-align: center;" class="site-reveal">
        {page.values?.badge && <div class="site-badge">{page.values.badge}</div>}
        <h2 class="site-display site-display-lg" style="margin-top: 1rem;">{page.values?.heading}</h2>
      </div>

      <div class="site-values-grid">
        {(page.values?.cards ?? []).map((v, i) => (
          <div class={`site-val-card-about site-reveal site-reveal-d${(i % 6) + 1}`}>
            <div class="site-val-header">
              <div class="site-val-icon-wrap" set:html={siteIcon(v.iconKey, 24)} />
              {v.num && <span class="site-val-num">{v.num}</span>}
            </div>
            <h4 class="site-val-title">{v.title}</h4>
            {v.description && <p class="site-val-desc">{v.description}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== JOURNEY ===================== -->
  <section class="site-section site-bg-dark site-texture">
    <div class="site-container">
      <div style="text-align: center;" class="site-reveal">
        {page.timeline?.badge && <div class="site-badge site-badge-light">{page.timeline.badge}</div>}
        <h2 class="site-display site-display-lg" style="margin-top: 1rem;">{page.timeline?.heading}</h2>
      </div>

      {journeyHtml && <div class="site-journey-content site-reveal site-reveal-d2" set:html={journeyHtml} />}
    </div>
  </section>

  <!-- ===================== CTA BAND ===================== -->
  <section class="site-cta-band">
    <div class="site-container site-reveal">
      <div class="site-cta-content">
        <h2 class="site-display site-display-lg" style="color: white;">
          {page.cta?.heading}
        </h2>
        {page.cta?.text && <p class="site-cta-desc">{page.cta.text}</p>}
      </div>
      <div class="site-cta-actions">
        {page.cta?.primaryButton && <a href={page.cta.primaryButton.href} class="site-btn site-btn-white">{page.cta.primaryButton.label}</a>}
        {page.cta?.phoneHref && page.cta.phoneLabel && (
          <a href={page.cta.phoneHref} class="site-cta-phone">
            <span set:html={siteIcon('phone', 18)} />
            {page.cta.phoneLabel}
          </a>
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===================== HERO ===================== */
  .site-about-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 860px) {
    .site-about-hero-grid { grid-template-columns: 1.1fr 1fr; gap: 4rem; }
  }

  .site-about-hero-img-inner {
    border-radius: var(--site-radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ===================== MISSION / VISION ===================== */
  .site-mv-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .site-mv-grid { grid-template-columns: 1fr 1fr; }
  }

  .site-mv-card {
    background: white;
    border: 1px solid rgba(42, 42, 42, 0.1);
    border-radius: var(--site-radius-lg);
    padding: 2.5rem 2rem;
    position: relative;
  }

  .site-mv-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--site-ember);
    border-radius: var(--site-radius-lg) var(--site-radius-lg) 0 0;
  }

  /* ===================== VALUES ===================== */
  .site-values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 3rem;
  }

  @media (min-width: 640px) {
    .site-values-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 960px) {
    .site-values-grid { grid-template-columns: 1fr 1fr 1fr; }
  }

  .site-val-card-about {
    background: white;
    border: 1px solid rgba(42, 42, 42, 0.1);
    border-radius: var(--site-radius-lg);
    padding: 2rem 1.75rem;
    transition: all 0.4s var(--site-ease);
  }

  .site-val-card-about:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px -8px rgba(42, 42, 42, 0.12);
    border-color: rgba(232, 97, 26, 0.2);
  }

  .site-val-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .site-val-icon-wrap {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--site-cream);
    border-radius: var(--site-radius);
    color: var(--site-ember);
  }

  .site-val-num {
    font-family: var(--site-font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--site-sand);
    line-height: 1;
  }

  .site-val-title {
    font-family: var(--site-font-body);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--site-charcoal);
    margin-bottom: 0.5rem;
  }

  .site-val-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--site-charcoal-light);
  }

  /* ===================== JOURNEY CONTENT ===================== */
  .site-journey-content {
    max-width: 720px;
    margin: 3rem auto 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 1rem;
    line-height: 1.8;
  }

  .site-journey-content :global(* + *) {
    margin-top: 1rem;
  }

  .site-journey-content :global(h2),
  .site-journey-content :global(h3),
  .site-journey-content :global(h4) {
    color: white;
    font-family: var(--site-font-display);
    font-weight: 800;
    line-height: 1.1;
  }

  .site-journey-content :global(h2) { font-size: clamp(2rem, 5vw, 3.5rem); }
  .site-journey-content :global(h3) { font-size: clamp(1.6rem, 4vw, 2.5rem); }
  .site-journey-content :global(h4) { font-size: 1.35rem; }

  .site-journey-content :global(strong) {
    color: var(--site-gold);
    font-weight: 800;
  }

  .site-journey-content :global(a) {
    color: var(--site-gold);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .site-journey-content :global(ul),
  .site-journey-content :global(ol) {
    padding-left: 1.35rem;
  }

  .site-journey-content :global(li + li) {
    margin-top: 0.5rem;
  }

  .site-journey-content :global(blockquote) {
    border-left: 4px solid var(--site-ember);
    color: rgba(255, 255, 255, 0.84);
    font-family: var(--site-font-display);
    font-size: clamp(1.35rem, 3vw, 2rem);
    font-style: italic;
    line-height: 1.25;
    padding-left: 1.25rem;
  }

  .site-journey-content :global(code) {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    color: white;
    font-size: 0.9em;
    padding: 0.15rem 0.35rem;
  }

</style>
