---
// Contact CTA section
---

<section id="contact" class="relative py-section-sm lg:py-section bg-charcoal-dark overflow-hidden">
  <!-- Architectural grid lines -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Orange glow accent -->
  <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] opacity-8" style="background: radial-gradient(circle, rgba(232,97,26,0.15) 0%, transparent 70%);"></div>

  <!-- Roofline decorative -->
  <div class="absolute top-12 right-12 opacity-[0.04] hidden lg:block">
    <svg width="200" height="140" viewBox="0 0 300 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M150 10L290 120H270L150 30L30 120H10L150 10Z" stroke="#E8611A" stroke-width="2"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- Left: CTA content -->
      <div class="lg:py-8">
        <p class="animate-on-scroll font-heading text-sm font-medium tracking-[0.3em] uppercase text-ember mb-4">
          Get Started
        </p>
        <h2 class="animate-on-scroll font-display text-4xl lg:text-6xl text-white leading-[1.05] mb-6" style="animation-delay: 80ms;">
          Ready to Build <br/>Something Great?
        </h2>
        <span class="ember-line animate-on-scroll" style="animation-delay: 160ms;"></span>
        <p class="animate-on-scroll font-body text-lg text-steel leading-relaxed mt-6 max-w-lg" style="animation-delay: 200ms;">
          Every great build starts with a conversation. Tell us about your
          project and let's explore what's possible together. Free consultations,
          no obligation.
        </p>

        <!-- Contact details -->
        <div class="mt-12 space-y-6 animate-on-scroll" style="animation-delay: 300ms;">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-sm bg-ember/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-ember" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <span class="font-heading text-xs font-medium tracking-wider uppercase text-steel block">Phone</span>
              <a href="tel:+15551234567" class="font-body text-lg text-white hover:text-ember transition-colors">(555) 123-4567</a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-sm bg-ember/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-ember" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <span class="font-heading text-xs font-medium tracking-wider uppercase text-steel block">Email</span>
              <a href="mailto:info@youfirstconstruction.com" class="font-body text-lg text-white hover:text-ember transition-colors">info@youfirstconstruction.com</a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-sm bg-ember/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-ember" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <span class="font-heading text-xs font-medium tracking-wider uppercase text-steel block">Location</span>
              <span class="font-body text-lg text-white">Serving the Greater Metro Area</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Contact form -->
      <div class="animate-on-scroll" style="animation-delay: 200ms;">
        <form class="bg-charcoal/50 backdrop-blur-sm p-8 lg:p-10 border border-white/5">
          <div class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="font-heading text-xs font-medium tracking-wider uppercase text-steel block mb-2">
                  First Name
                </label>
                <input
                  type="text"
                  class="w-full bg-transparent border-b border-white/15 text-white font-body text-base py-3 px-0 focus:outline-none focus:border-ember transition-colors placeholder:text-white/20"
                  placeholder="John"
                />
              </div>
              <div>
                <label class="font-heading text-xs font-medium tracking-wider uppercase text-steel block mb-2">
                  Last Name
                </label>
                <input
                  type="text"
                  class="w-full bg-transparent border-b border-white/15 text-white font-body text-base py-3 px-0 focus:outline-none focus:border-ember transition-colors placeholder:text-white/20"
                  placeholder="Doe"
                />
              </div>
            </div>

            <div>
              <label class="font-heading text-xs font-medium tracking-wider uppercase text-steel block mb-2">
                Email
              </label>
              <input
                type="email"
                class="w-full bg-transparent border-b border-white/15 text-white font-body text-base py-3 px-0 focus:outline-none focus:border-ember transition-colors placeholder:text-white/20"
                placeholder="john@example.com"
              />
            </div>

            <div>
              <label class="font-heading text-xs font-medium tracking-wider uppercase text-steel block mb-2">
                Project Type
              </label>
              <select class="w-full bg-transparent border-b border-white/15 text-white/60 font-body text-base py-3 px-0 focus:outline-none focus:border-ember transition-colors appearance-none cursor-pointer">
                <option value="" class="bg-charcoal-dark">Select a service...</option>
                <option value="custom-home" class="bg-charcoal-dark">Custom Home</option>
                <option value="renovation" class="bg-charcoal-dark">Renovation</option>
                <option value="adu" class="bg-charcoal-dark">ADU</option>
                <option value="commercial" class="bg-charcoal-dark">Commercial</option>
                <option value="outdoor" class="bg-charcoal-dark">Outdoor Living</option>
                <option value="consulting" class="bg-charcoal-dark">Consulting</option>
              </select>
            </div>

            <div>
              <label class="font-heading text-xs font-medium tracking-wider uppercase text-steel block mb-2">
                Tell Us About Your Project
              </label>
              <textarea
                rows="4"
                class="w-full bg-transparent border-b border-white/15 text-white font-body text-base py-3 px-0 focus:outline-none focus:border-ember transition-colors resize-none placeholder:text-white/20"
                placeholder="Describe your vision..."
              ></textarea>
            </div>

            <button type="submit" class="btn-primary w-full font-heading text-sm font-semibold tracking-wider uppercase py-4 mt-4">
              Send Message
            </button>

            <p class="font-body text-xs text-steel/60 text-center mt-4">
              We typically respond within 24 hours. Your information is never shared.
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
