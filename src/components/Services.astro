---
// Services section

const services = [
  {
    title: "Custom Homes",
    description: "From architectural design through final walkthrough, we build bespoke homes that reflect your lifestyle. Every detail is crafted to your exact specifications.",
    icon: "home",
  },
  {
    title: "Renovations",
    description: "Transform your existing space with precision renovations. Whether it's a kitchen overhaul or a complete reimagining, we breathe new life into every room.",
    icon: "renovation",
  },
  {
    title: "ADUs",
    description: "Accessory Dwelling Units that maximize your property's potential. Thoughtfully designed spaces for extended family, rental income, or home offices.",
    icon: "adu",
  },
  {
    title: "Commercial",
    description: "Purpose-built commercial spaces designed for productivity and brand expression. From retail to office, we build environments that work.",
    icon: "commercial",
  },
  {
    title: "Outdoor Living",
    description: "Extend your living space beyond four walls. Patios, outdoor kitchens, pergolas, and landscape architecture that create unforgettable gathering places.",
    icon: "outdoor",
  },
  {
    title: "Consulting",
    description: "Expert guidance on feasibility, budgeting, and project planning. Get clear answers before breaking ground — no obligation, no pressure.",
    icon: "consulting",
  },
];

const iconPaths: Record<string, string> = {
  home: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
  renovation: "M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z",
  adu: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  commercial: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  outdoor: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  consulting: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01",
};
---

<section id="services" class="relative py-section-sm lg:py-section">
  <!-- Angled top edge overlay -->
  <div class="absolute top-0 left-0 right-0 h-24 bg-charcoal-dark angle-cut"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <!-- Section header -->
    <div class="mb-16 lg:mb-24 max-w-2xl">
      <p class="animate-on-scroll font-heading text-sm font-medium tracking-[0.3em] uppercase text-ember mb-4">
        What We Do
      </p>
      <h2 class="animate-on-scroll font-display text-4xl lg:text-6xl text-charcoal-dark leading-[1.05] mb-6" style="animation-delay: 80ms;">
        Built Around <br />Your Vision
      </h2>
      <span class="ember-line animate-on-scroll" style="animation-delay: 160ms;"></span>
      <p class="animate-on-scroll font-body text-lg text-slate mt-6 leading-relaxed" style="animation-delay: 200ms;">
        Every project begins with listening. We offer a full spectrum of construction
        services, each delivered with the precision and care that defines You First.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 stagger-children animate-on-scroll">
      {services.map((service) => (
        <div class="service-card relative bg-white p-8 lg:p-10 group cursor-default">
          <!-- Icon -->
          <div class="w-14 h-14 rounded-sm bg-ember-glow flex items-center justify-center mb-6 group-hover:bg-ember transition-colors duration-500">
            <svg
              class="w-6 h-6 text-ember group-hover:text-white transition-colors duration-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[service.icon]} />
            </svg>
          </div>

          <!-- Content -->
          <h3 class="font-heading text-xl font-semibold text-charcoal-dark mb-3">
            {service.title}
          </h3>
          <p class="font-body text-base text-slate leading-relaxed">
            {service.description}
          </p>

          <!-- Arrow -->
          <div class="mt-6 flex items-center gap-2 text-ember opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-x-[-8px] group-hover:translate-x-0">
            <span class="font-heading text-sm font-medium tracking-wider uppercase">Learn More</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
