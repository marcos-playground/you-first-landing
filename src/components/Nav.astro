---
// Navigation component for You First Construction
interface Props {
  homeHref?: string;
  versionsHref?: string;
  showSectionLinks?: boolean;
}

const {
  homeHref = '/',
  versionsHref,
  showSectionLinks = true,
} = Astro.props;
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="flex items-center justify-between h-20 lg:h-24">
      <!-- Logo -->
      <a href={homeHref} class="relative z-10 flex items-center gap-3 group">
        <img
          src="/logo.png"
          alt="You First Construction"
          class="h-12 lg:h-14 w-auto transition-transform duration-500 group-hover:scale-105"
        />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-10">
        {showSectionLinks && (
          <>
            <a href="#services" class="nav-link font-heading text-sm font-medium tracking-widest uppercase text-charcoal-light">Services</a>
            <a href="#projects" class="nav-link font-heading text-sm font-medium tracking-widest uppercase text-charcoal-light">Projects</a>
            <a href="#about" class="nav-link font-heading text-sm font-medium tracking-widest uppercase text-charcoal-light">About</a>
            <a href="#contact" class="nav-link font-heading text-sm font-medium tracking-widest uppercase text-charcoal-light">Contact</a>
          </>
        )}
        {versionsHref && (
          <a href={versionsHref} class="nav-link font-heading text-sm font-medium tracking-widest uppercase text-charcoal-light">
            All Versions
          </a>
        )}
        {showSectionLinks && (
          <a href="#contact" class="btn-primary font-heading text-sm font-semibold tracking-wider uppercase px-7 py-3">
            Get a Quote
          </a>
        )}
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden relative z-10 w-10 h-10 flex flex-col justify-center items-center gap-1.5"
        aria-label="Toggle menu"
      >
        <span class="mobile-line w-6 h-0.5 bg-charcoal transition-all duration-300 origin-center"></span>
        <span class="mobile-line w-6 h-0.5 bg-charcoal transition-all duration-300 origin-center"></span>
        <span class="mobile-line w-4 h-0.5 bg-charcoal transition-all duration-300 origin-center ml-auto"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-bone/98 backdrop-blur-md flex flex-col justify-center items-center gap-8 opacity-0 pointer-events-none transition-opacity duration-500 lg:hidden"
  >
    {showSectionLinks && (
      <>
        <a href="#services" class="mobile-nav-link font-display text-4xl text-charcoal hover:text-ember transition-colors duration-300">Services</a>
        <a href="#projects" class="mobile-nav-link font-display text-4xl text-charcoal hover:text-ember transition-colors duration-300">Projects</a>
        <a href="#about" class="mobile-nav-link font-display text-4xl text-charcoal hover:text-ember transition-colors duration-300">About</a>
        <a href="#contact" class="mobile-nav-link font-display text-4xl text-charcoal hover:text-ember transition-colors duration-300">Contact</a>
      </>
    )}
    {versionsHref && (
      <a href={versionsHref} class="mobile-nav-link font-display text-4xl text-charcoal hover:text-ember transition-colors duration-300">
        All Versions
      </a>
    )}
    {showSectionLinks && (
      <a href="#contact" class="btn-primary font-heading text-base font-semibold tracking-wider uppercase px-10 py-4 mt-4">
        Get a Quote
      </a>
    )}
  </div>
</nav>

<!-- Nav background on scroll -->
<script>
  const nav = document.getElementById('main-nav');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  let menuOpen = false;

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      nav?.classList.add('bg-bone/95', 'backdrop-blur-md', 'shadow-sm');
    } else {
      nav?.classList.remove('bg-bone/95', 'backdrop-blur-md', 'shadow-sm');
    }
  });

  // Mobile menu toggle
  mobileMenuBtn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      mobileMenu?.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu?.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
      // Animate hamburger to X
      const lines = mobileMenuBtn.querySelectorAll('.mobile-line');
      lines[0]?.classList.add('rotate-45', 'translate-y-[4px]');
      lines[1]?.classList.add('opacity-0');
      lines[2]?.classList.add('-rotate-45', '-translate-y-[4px]', 'w-6');
    } else {
      mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
      const lines = mobileMenuBtn.querySelectorAll('.mobile-line');
      lines[0]?.classList.remove('rotate-45', 'translate-y-[4px]');
      lines[1]?.classList.remove('opacity-0');
      lines[2]?.classList.remove('-rotate-45', '-translate-y-[4px]', 'w-6');
    }
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';
      const lines = mobileMenuBtn?.querySelectorAll('.mobile-line');
      lines?.[0]?.classList.remove('rotate-45', 'translate-y-[4px]');
      lines?.[1]?.classList.remove('opacity-0');
      lines?.[2]?.classList.remove('-rotate-45', '-translate-y-[4px]', 'w-6');
    });
  });
</script>
