---
// Projects section — portfolio showcase

const projects = [
  {
    title: "The Ridgeline Estate",
    category: "Custom Home",
    description: "4,800 sq ft modern farmhouse with panoramic mountain views",
    span: "large",
  },
  {
    title: "Elm Street Revival",
    category: "Renovation",
    description: "Complete gut renovation of a 1920s craftsman bungalow",
    span: "small",
  },
  {
    title: "Oakwood ADU",
    category: "ADU",
    description: "650 sq ft detached guest suite with modern finishes",
    span: "small",
  },
  {
    title: "Summit Commercial",
    category: "Commercial",
    description: "12,000 sq ft mixed-use retail and office development",
    span: "large",
  },
];
---

<section id="projects" class="relative py-section-sm lg:py-section bg-charcoal-dark angle-cut-both overflow-hidden">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Orange glow -->
  <div class="absolute top-0 right-0 w-96 h-96 opacity-10" style="background: radial-gradient(circle, rgba(232,97,26,0.4) 0%, transparent 70%);"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 pt-12">
    <!-- Section header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-16 lg:mb-20 gap-8">
      <div class="max-w-2xl">
        <p class="animate-on-scroll font-heading text-sm font-medium tracking-[0.3em] uppercase text-ember mb-4">
          Our Work
        </p>
        <h2 class="animate-on-scroll font-display text-4xl lg:text-6xl text-white leading-[1.05] mb-6" style="animation-delay: 80ms;">
          Projects That <br />Speak for Themselves
        </h2>
        <span class="ember-line animate-on-scroll" style="animation-delay: 160ms;"></span>
      </div>
      <a
        href="#contact"
        class="animate-on-scroll btn-outline border-white/20 text-white hover:border-ember hover:text-ember font-heading text-sm font-semibold tracking-wider uppercase px-8 py-3 self-start lg:self-auto"
        style="animation-delay: 200ms;"
      >
        View All Projects
      </a>
    </div>

    <!-- Projects grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
      {projects.map((project, index) => (
        <div
          class:list={[
            "project-card relative group cursor-pointer animate-on-scroll",
            project.span === "large" ? "lg:col-span-7" : "lg:col-span-5",
          ]}
          style={`animation-delay: ${index * 120}ms;`}
        >
          <!-- Placeholder image area -->
          <div class="relative aspect-[4/3] lg:aspect-[16/10] bg-charcoal overflow-hidden">
            <!-- Placeholder pattern -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="text-center">
                <svg class="w-16 h-16 text-white/10 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span class="text-white/10 font-heading text-sm tracking-wider uppercase">Project Photo</span>
              </div>
            </div>
            <!-- Gradient pattern for visual interest -->
            <div
              class="project-image absolute inset-0"
              style={`background: linear-gradient(${135 + index * 30}deg, rgba(232,97,26,${0.05 + index * 0.02}) 0%, rgba(61,61,61,0.8) 100%);`}
            ></div>

            <!-- Hover overlay -->
            <div class="project-overlay absolute inset-0 bg-gradient-to-t from-charcoal-dark/90 via-charcoal-dark/40 to-transparent opacity-60">
            </div>

            <!-- Content overlay -->
            <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-8">
              <span class="font-heading text-xs font-medium tracking-[0.25em] uppercase text-ember mb-2 block">
                {project.category}
              </span>
              <h3 class="font-display text-2xl lg:text-3xl text-white mb-2">
                {project.title}
              </h3>
              <p class="font-body text-sm text-white/60 max-w-md">
                {project.description}
              </p>

              <!-- View project arrow -->
              <div class="mt-4 flex items-center gap-2 text-ember transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
                <span class="font-heading text-xs font-semibold tracking-wider uppercase">View Project</span>
                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
