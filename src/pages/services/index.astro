---
import Layout from '../../layouts/Layout.astro';
import { siteIcon } from '../../lib/icons';
import { cmsImageFallbackSrc, getPage, type CtaBlock, type PageDocument, type PageHero, type ProcessStep, type ServiceCard } from '../../lib/sanityPages';

type ServicesPage = PageDocument & {
  hero: PageHero;
  newConstruction?: {
    label?: string;
    heading?: string;
    text?: string;
    cards?: ServiceCard[];
  };
  remodeling?: {
    label?: string;
    heading?: string;
    text?: string;
    cards?: ServiceCard[];
  };
  process?: {
    badge?: string;
    heading?: string;
    steps?: ProcessStep[];
  };
  cta?: CtaBlock;
};

const page = await getPage<ServicesPage>('servicesPage');
---

<Layout
  title={page.seo.title}
  description={page.seo.description}
  currentPage="services"
>
  <!-- ===================== PAGE HERO — dark ===================== -->
  <section class="site-page-hero site-bg-dark site-texture">
    <div class="site-container">
      <div class="site-page-hero-grid has-image">
        <div>
          <nav class="site-breadcrumb site-reveal" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="site-breadcrumb-sep">/</span>
            <span class="site-breadcrumb-current">Services</span>
          </nav>

          {page.hero.badge && <div class="site-badge site-badge-light site-reveal">{page.hero.badge}</div>}
          <h1 class="site-display site-display-xl site-reveal site-reveal-d1" style="margin-top: 1rem;">
            {page.hero.heading}
          </h1>
          <div class="site-ember-bar site-reveal site-reveal-d2" style="margin-top: 1.25rem;"></div>
          {page.hero.text && <p class="site-text site-reveal site-reveal-d3" style="max-width: 560px; margin-top: 1rem;">{page.hero.text}</p>}
        </div>

        <div class="site-page-hero-media site-reveal site-reveal-d2">
          <img
            src={page.hero.image?.asset?.url ?? cmsImageFallbackSrc}
            alt={page.hero.image?.alt ?? ''}
            class:list={['site-cms-image', { 'is-empty': !page.hero.image?.asset?.url }]}
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== NEW CONSTRUCTION ===================== -->
  <section class="site-section site-bg-cream site-texture">
    <div class="site-container">
      <div class="site-svc-section-intro site-reveal">
        {page.newConstruction?.label && <span class="site-label">{page.newConstruction.label}</span>}
        <h2 class="site-display site-display-lg" style="margin-top: 0.5rem;">{page.newConstruction?.heading}</h2>
        {page.newConstruction?.text && <p class="site-text" style="max-width: 540px; margin-top: 0.75rem;">{page.newConstruction.text}</p>}
      </div>

      <div class="site-svc-grid">
        {(page.newConstruction?.cards ?? []).map((svc, i) => (
          <div class={`site-svc-card-page site-reveal site-reveal-d${i + 1}`}>
            <div class="site-svc-icon-wrap" set:html={siteIcon(svc.iconKey)} />
            <div class="site-svc-card-body">
              <h3 class="site-svc-name">{svc.title}</h3>
              {svc.description && <p class="site-svc-desc">{svc.description}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== REMODELING ===================== -->
  <section class="site-section">
    <div class="site-container">
      <div class="site-svc-section-intro site-reveal">
        {page.remodeling?.label && <span class="site-label">{page.remodeling.label}</span>}
        <h2 class="site-display site-display-lg" style="margin-top: 0.5rem;">{page.remodeling?.heading}</h2>
        {page.remodeling?.text && <p class="site-text" style="max-width: 540px; margin-top: 0.75rem;">{page.remodeling.text}</p>}
      </div>

      <div class="site-svc-grid">
        {(page.remodeling?.cards ?? []).map((svc, i) => (
          <div class={`site-svc-card-page site-reveal site-reveal-d${i + 1}`}>
            <div class="site-svc-icon-wrap" set:html={siteIcon(svc.iconKey)} />
            <div class="site-svc-card-body">
              <h3 class="site-svc-name">{svc.title}</h3>
              {svc.description && <p class="site-svc-desc">{svc.description}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== PROCESS ===================== -->
  <section class="site-section site-bg-dark site-texture">
    <div class="site-container">
      <div style="text-align: center;" class="site-reveal">
        {page.process?.badge && <div class="site-badge site-badge-light">{page.process.badge}</div>}
        <h2 class="site-display site-display-lg" style="margin-top: 1rem;">{page.process?.heading}</h2>
      </div>

      <div class="site-process-grid">
        {(page.process?.steps ?? []).map((p, i) => (
          <div class={`site-process-step site-reveal site-reveal-d${i + 1}`}>
            <div class="site-process-num">{p.step}</div>
            <div class="site-process-line"></div>
            <h3 class="site-process-title">{p.title}</h3>
            {p.description && <p class="site-process-desc">{p.description}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== CTA BAND ===================== -->
  <section class="site-cta-band">
    <div class="site-container site-reveal">
      <div class="site-cta-content">
        <h2 class="site-display site-display-lg" style="color: white;">
          {page.cta?.heading}
        </h2>
        {page.cta?.text && <p class="site-cta-desc">{page.cta.text}</p>}
      </div>
      <div class="site-cta-actions">
        {page.cta?.primaryButton && <a href={page.cta.primaryButton.href} class="site-btn site-btn-white">{page.cta.primaryButton.label}</a>}
        {page.cta?.phoneHref && page.cta.phoneLabel && (
          <a href={page.cta.phoneHref} class="site-cta-phone">
            <span set:html={siteIcon('phone', 18)} />
            {page.cta.phoneLabel}
          </a>
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===================== SERVICE CARDS ===================== */
  .site-svc-section-intro {
    margin-bottom: 2.5rem;
  }

  .site-svc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .site-svc-grid { grid-template-columns: 1fr 1fr; }
  }

  .site-svc-card-page {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: white;
    border: 1px solid rgba(42, 42, 42, 0.1);
    border-radius: var(--site-radius-lg);
    padding: 2rem;
    transition: all 0.4s var(--site-ease);
    position: relative;
    overflow: hidden;
  }

  .site-svc-card-page::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--site-ember);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--site-ease);
  }

  .site-svc-card-page:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px -8px rgba(42, 42, 42, 0.12);
    border-color: rgba(232, 97, 26, 0.2);
  }

  .site-svc-card-page:hover::before {
    transform: scaleX(1);
  }

  .site-svc-card-page .site-svc-icon-wrap {
    width: 52px;
    height: 52px;
    min-width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--site-cream);
    border-radius: var(--site-radius);
    color: var(--site-ember);
  }

  .site-svc-name {
    font-family: var(--site-font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--site-charcoal);
    margin-bottom: 0.375rem;
  }

  .site-svc-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--site-charcoal-light);
  }

  /* ===================== PROCESS ===================== */
  .site-process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 3rem;
  }

  @media (min-width: 640px) {
    .site-process-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 960px) {
    .site-process-grid { grid-template-columns: 1fr 1fr 1fr 1fr; }
  }

  .site-process-step {
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--site-radius-lg);
    transition: border-color 0.3s, background 0.3s;
  }

  .site-process-step:hover {
    border-color: rgba(232, 97, 26, 0.3);
    background: rgba(255, 255, 255, 0.06);
  }

  .site-process-num {
    font-family: var(--site-font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--site-ember);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .site-process-line {
    width: 32px;
    height: 3px;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 2px;
    margin: 0 auto 1rem;
  }

  .site-process-title {
    font-family: var(--site-font-body);
    font-size: 1.0625rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.5rem;
  }

  .site-process-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.55);
  }
</style>
