---
import Layout from '../../layouts/Layout.astro';

const projects = [
  {
    title: 'Riverstone Estate',
    category: 'Custom Home',
    location: 'Sugar Land, TX',
    sqft: '4,800',
    desc: 'A sprawling luxury custom home featuring an open floor plan, chef\'s kitchen, and resort-style outdoor living.',
    featured: true,
  },
  {
    title: 'Heights Kitchen & Bath',
    category: 'Remodel',
    location: 'Houston Heights, TX',
    sqft: '1,200',
    desc: 'Complete kitchen and bathroom transformation with custom cabinetry and quartz countertops.',
    featured: false,
  },
  {
    title: 'Midtown Office Complex',
    category: 'Commercial',
    location: 'Midtown, Houston',
    sqft: '12,000',
    desc: 'A modern Class A office building with mixed-use retail space on the ground floor.',
    featured: false,
  },
  {
    title: 'Memorial Park Modern',
    category: 'Custom Home',
    location: 'Memorial, Houston',
    sqft: '5,200',
    desc: 'Contemporary design meets Texas warmth — floor-to-ceiling glass, natural stone, and smart home integration.',
    featured: true,
  },
  {
    title: 'Katy Family Home',
    category: 'Spec Home',
    location: 'Katy, TX',
    sqft: '3,400',
    desc: 'A move-in ready family home with premium finishes, energy-efficient systems, and a spacious backyard.',
    featured: false,
  },
  {
    title: 'Pearland Restoration',
    category: 'Restoration',
    location: 'Pearland, TX',
    sqft: '2,800',
    desc: 'Full property restoration after flood damage — rebuilt from studs with upgraded finishes and flood-resistant materials.',
    featured: false,
  },
  {
    title: 'Galleria Retail Build-Out',
    category: 'Commercial',
    location: 'Galleria Area, Houston',
    sqft: '6,500',
    desc: 'High-end retail tenant improvement with custom fixtures, lighting design, and branded environment.',
    featured: false,
  },
  {
    title: 'Woodlands Grand',
    category: 'Custom Home',
    location: 'The Woodlands, TX',
    sqft: '6,100',
    desc: 'Estate-level custom home with a wine cellar, home theater, pool house, and 4-car garage.',
    featured: true,
  },
];

const categories = ['All', 'Custom Home', 'Remodel', 'Commercial', 'Spec Home', 'Restoration'];
---

<Layout
  title="Projects | You First Construction"
  description="Explore our portfolio of custom homes, remodels, commercial builds, and restoration projects across the Houston area."
  currentPage="projects"
>
  <!-- ===================== HERO ===================== -->
  <section class="site-page-hero site-bg-dark site-texture">
    <div class="site-container">
      <nav class="site-breadcrumb site-reveal" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="site-breadcrumb-sep">/</span>
        <span class="site-breadcrumb-current">Projects</span>
      </nav>
      <div class="site-badge site-badge-light site-reveal">Our Portfolio</div>
      <h1 class="site-display site-display-xl site-reveal site-reveal-d1" style="margin-top: 1rem;">
        Craftsmanship<br />you can see.
      </h1>
      <div class="site-ember-bar site-reveal site-reveal-d2" style="margin-top: 1.25rem;"></div>
      <p class="site-text site-reveal site-reveal-d3" style="max-width: 520px; margin-top: 1rem;">
        From custom estates to commercial complexes, every project tells a story of collaboration, quality, and attention to detail.
      </p>
    </div>
  </section>

  <!-- ===================== FILTER + GRID ===================== -->
  <section class="site-section" style="padding-top: 3rem;">
    <div class="site-container">
      <!-- Filter pills -->
      <div class="site-filter-bar site-reveal">
        {categories.map((cat) => (
          <button
            class:list={['site-filter-pill', { 'is-active': cat === 'All' }]}
            data-filter={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Project grid -->
      <div class="site-project-grid">
        {projects.map((p, i) => (
          <div
            class:list={['site-project-card', { 'is-featured': p.featured }, `site-reveal site-reveal-d${(i % 4) + 1}`]}
            data-category={p.category}
          >
            <div class="site-proj-img-wrap">
              <div class="site-img-placeholder" role="img" aria-label={p.title}></div>
              <div class="site-proj-badge-wrap">
                <span class="site-proj-cat">{p.category}</span>
              </div>
            </div>
            <div class="site-proj-info">
              <h3 class="site-proj-title">{p.title}</h3>
              <p class="site-proj-desc">{p.desc}</p>
              <div class="site-proj-meta">
                <span>{p.location}</span>
                <span class="site-proj-dot"></span>
                <span>{p.sqft} sq ft</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== CTA BAND ===================== -->
  <section class="site-cta-band">
    <div class="site-container site-reveal">
      <div class="site-cta-content">
        <h2 class="site-display site-display-lg" style="color: white;">
          Have a project in mind?
        </h2>
        <p class="site-cta-desc">
          We would love to hear about it. Reach out for a free consultation and let us explore what is possible together.
        </p>
      </div>
      <div class="site-cta-actions">
        <a href="/contact" class="site-btn site-btn-white">Start the Conversation</a>
        <a href="tel:5550123456" class="site-cta-phone">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          (555) 012-3456
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===================== FILTER BAR ===================== */
  .site-filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .site-filter-pill {
    font-family: var(--site-font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--site-charcoal-light);
    background: rgba(42, 42, 42, 0.05);
    border: 1px solid rgba(42, 42, 42, 0.08);
    border-radius: var(--site-radius);
    padding: 0.5rem 1.25rem;
    cursor: pointer;
    transition: all 0.25s var(--site-ease);
  }

  .site-filter-pill:hover {
    background: rgba(42, 42, 42, 0.1);
    color: var(--site-charcoal);
  }

  .site-filter-pill.is-active {
    color: white;
    background: var(--site-ember);
    border-color: var(--site-ember);
    font-weight: 700;
  }

  /* ===================== PROJECT GRID ===================== */
  .site-project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .site-project-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 960px) {
    .site-project-grid { grid-template-columns: 1fr 1fr 1fr; }
    .site-project-card.is-featured { grid-column: span 2; }
  }

  .site-project-card {
    border-radius: var(--site-radius-lg);
    overflow: hidden;
    background: white;
    border: 1px solid rgba(42, 42, 42, 0.1);
    transition: transform 0.4s var(--site-ease), box-shadow 0.4s, border-color 0.3s;
  }

  .site-project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px -8px rgba(42, 42, 42, 0.12);
    border-color: rgba(232, 97, 26, 0.2);
  }

  .site-proj-img-wrap {
    position: relative;
    overflow: hidden;
  }

  .site-proj-img-wrap .site-img-placeholder {
    aspect-ratio: 16 / 10;
    transition: transform 0.6s var(--site-ease);
  }

  .site-project-card.is-featured .site-proj-img-wrap .site-img-placeholder {
    aspect-ratio: 16 / 9;
  }

  .site-project-card:hover .site-img-placeholder {
    transform: scale(1.04);
  }

  .site-proj-badge-wrap {
    position: absolute;
    top: 0.875rem;
    left: 0.875rem;
  }

  .site-proj-cat {
    font-family: var(--site-font-body);
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: white;
    background: rgba(42, 42, 42, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.35rem 0.875rem;
    border-radius: var(--site-radius);
  }

  .site-proj-info {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .site-proj-title {
    font-family: var(--site-font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--site-charcoal);
    margin-bottom: 0.375rem;
  }

  .site-proj-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--site-charcoal-light);
    margin-bottom: 0.75rem;
  }

  .site-proj-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--site-font-body);
    font-size: 0.8125rem;
    color: var(--site-stone);
    font-weight: 500;
  }

  .site-proj-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--site-sand);
  }
</style>

<script>
  const pills = document.querySelectorAll('.site-filter-pill');
  const cards = document.querySelectorAll('.site-project-card');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      pills.forEach((p) => p.classList.remove('is-active'));
      pill.classList.add('is-active');

      const filter = pill.getAttribute('data-filter');

      cards.forEach((card) => {
        const cat = card.getAttribute('data-category');
        if (filter === 'All' || cat === filter) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
