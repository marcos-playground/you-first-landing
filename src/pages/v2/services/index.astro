---
import V2Layout from '../../../layouts/V2Layout.astro';

const newConstruction = [
  {
    tag: "NC-01",
    title: "Commercial & Residential",
    desc: "Full-scale new builds for both commercial spaces and residential properties. From office complexes and retail spaces to family homes and multi-unit developments, we manage every phase — permitting, foundation, framing, MEP, finishes, and final walkthrough.",
  },
  {
    tag: "NC-02",
    title: "Custom Homes",
    desc: "Bespoke homes designed and built to your exact vision. We collaborate with your architect or bring our own design partners to deliver a one-of-a-kind residence that reflects your lifestyle, taste, and long-term needs.",
  },
  {
    tag: "NC-03",
    title: "Spec Homes",
    desc: "Homes built to the highest market standards on speculation. We identify premium lots, design for the target buyer, and deliver turnkey properties that set the bar for quality in the neighborhood.",
  },
  {
    tag: "NC-04",
    title: "Shell Construction",
    desc: "Structural shell builds that deliver the core framework — foundation, framing, roofing, and exterior enclosure — ready for your custom interior build-out. Ideal for developers and owner-builders who want structural integrity from a proven team.",
  },
];

const remodeling = [
  {
    tag: "RM-01",
    title: "Commercial & Residential",
    desc: "Transform existing spaces to meet evolving needs. Whether updating a storefront, reimagining an office layout, or renovating a family home room-by-room, we deliver seamless transitions with minimal disruption.",
  },
  {
    tag: "RM-02",
    title: "High-End Remodels",
    desc: "Luxury renovations that elevate every surface, system, and detail. Premium imported materials, master craftsmanship, and design-forward thinking for discerning clients who expect the extraordinary.",
  },
  {
    tag: "RM-03",
    title: "Restoration & Disaster Recovery",
    desc: "Recovery and structural restoration for properties affected by fire, water, storms, earthquakes, or time. We work with insurance providers and bring buildings back — often better than before the damage occurred.",
  },
];
---

<V2Layout title="Services | You First Construction" currentPage="services">

  <!-- Page header -->
  <div class="v2-page-header">
    <div class="v2-page-header__inner">
      <div class="v2-page-header__crumb">
        <a href="/v2" style="color:var(--color-steel); text-decoration:none;">Home</a>
        <span>/</span>
        Services
      </div>
      <h1>What We <span style="color:var(--color-ember)">Build</span></h1>
      <p>Two core divisions. One standard of excellence. Every project gets our full expertise, regardless of scale.</p>
    </div>
  </div>

  <!-- New Construction -->
  <section class="v2-section">
    <div class="v2-svc-division">
      <div class="v2-svc-division__header">
        <div class="v2-svc-division__label">
          <div class="v2-svc-marker"></div>
          <span>New Construction</span>
        </div>
        <div class="v2-svc-division__line"></div>
        <span class="v2-svc-division__count">{newConstruction.length} Services</span>
      </div>

      <div class="v2-svc-grid">
        {newConstruction.map((svc) => (
          <div class="v2-svc-card">
            <span class="v2-svc-card__tag">{svc.tag}</span>
            <h3 class="v2-svc-card__title">{svc.title}</h3>
            <p class="v2-svc-card__desc">{svc.desc}</p>
            <div class="v2-svc-card__bar"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="v2-hr" style="max-width:1440px; margin:0 auto;" />

  <!-- Remodeling -->
  <section class="v2-section">
    <div class="v2-svc-division">
      <div class="v2-svc-division__header">
        <div class="v2-svc-division__label">
          <div class="v2-svc-marker v2-svc-marker--outline"></div>
          <span>Remodeling</span>
        </div>
        <div class="v2-svc-division__line"></div>
        <span class="v2-svc-division__count">{remodeling.length} Services</span>
      </div>

      <div class="v2-svc-grid">
        {remodeling.map((svc) => (
          <div class="v2-svc-card">
            <span class="v2-svc-card__tag">{svc.tag}</span>
            <h3 class="v2-svc-card__title">{svc.title}</h3>
            <p class="v2-svc-card__desc">{svc.desc}</p>
            <div class="v2-svc-card__bar"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process band -->
  <section class="v2-process-band">
    <div class="v2-process-band__inner">
      <span class="v2-bar" style="background:white;"></span>
      <h2>Our Process</h2>
      <div class="v2-process-steps">
        <div class="v2-process-step">
          <strong>01</strong>
          <h4>Consultation</h4>
          <p>We listen, assess your needs, and discuss feasibility, budget, and timeline — no obligation.</p>
        </div>
        <div class="v2-process-step">
          <strong>02</strong>
          <h4>Planning & Design</h4>
          <p>Detailed plans, material selection, permitting, and a transparent cost breakdown before we break ground.</p>
        </div>
        <div class="v2-process-step">
          <strong>03</strong>
          <h4>Construction</h4>
          <p>Our experienced crews execute with precision. Regular updates and quality checkpoints at every phase.</p>
        </div>
        <div class="v2-process-step">
          <strong>04</strong>
          <h4>Delivery</h4>
          <p>Final walkthrough, punch list completion, and handover. Your project, delivered exactly as promised.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="v2-section" style="text-align:center;">
    <span class="v2-bar" style="margin:0 auto;"></span>
    <h2 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,3.5rem); line-height:1; margin-top:1.25rem;">Have a Project in Mind?</h2>
    <p style="color:var(--color-slate); font-size:1.1rem; margin:1rem 0 2rem; max-width:480px; margin-left:auto; margin-right:auto;">
      Whether it's a question, a quote, or a full consultation — we're here to help.
    </p>
    <a href="/v2/contact" class="v2-btn v2-btn--fill">
      Contact Us
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </section>

</V2Layout>

<style>
  /* Division header */
  .v2-svc-division__header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .v2-svc-division__label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .v2-svc-marker {
    width: 14px;
    height: 14px;
    background: var(--color-ember);
  }
  .v2-svc-marker--outline {
    background: transparent;
    border: 3px solid var(--color-ember);
  }
  .v2-svc-division__line {
    flex: 1;
    height: 3px;
    background: var(--color-charcoal-dark);
  }
  .v2-svc-division__count {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-slate);
    white-space: nowrap;
  }

  /* Service grid */
  .v2-svc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 768px) {
    .v2-svc-grid { grid-template-columns: 1fr 1fr; }
  }

  /* Service card */
  .v2-svc-card {
    border: 3px solid var(--color-charcoal-dark);
    padding: 2.5rem;
    background: var(--color-bone);
    transition: all 0.35s ease;
    margin-top: -3px;
    margin-left: -3px;
  }
  .v2-svc-card:first-child { margin-top: 0; }
  @media (min-width: 768px) {
    .v2-svc-card:nth-child(2) { margin-top: 0; }
  }
  .v2-svc-card:hover {
    background: var(--color-charcoal-dark);
    color: white;
    z-index: 2;
    position: relative;
  }
  .v2-svc-card__tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-ember);
    display: block;
    margin-bottom: 1.5rem;
  }
  .v2-svc-card__title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1.1;
    margin-bottom: 1rem;
    transition: color 0.35s ease;
  }
  .v2-svc-card:hover .v2-svc-card__title { color: var(--color-ember); }
  .v2-svc-card__desc {
    font-size: 0.95rem;
    color: var(--color-slate);
    line-height: 1.7;
    transition: color 0.35s ease;
  }
  .v2-svc-card:hover .v2-svc-card__desc { color: var(--color-steel); }
  .v2-svc-card__bar {
    width: 0;
    height: 4px;
    background: var(--color-ember);
    margin-top: 1.5rem;
    transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .v2-svc-card:hover .v2-svc-card__bar { width: 48px; }

  /* Process band */
  .v2-process-band {
    background: var(--color-charcoal-dark);
    color: white;
  }
  .v2-process-band__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 5rem 2rem;
  }
  @media (min-width: 1024px) {
    .v2-process-band__inner { padding: 7rem 2rem; }
  }
  .v2-process-band h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    margin-top: 1.25rem;
    margin-bottom: 3rem;
  }
  .v2-process-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 768px) {
    .v2-process-steps { grid-template-columns: repeat(4, 1fr); }
  }
  .v2-process-step {
    padding: 2rem;
    border: 1px solid rgba(255,255,255,0.08);
    margin-top: -1px;
    margin-left: -1px;
  }
  .v2-process-step:first-child { margin-top: 0; }
  @media (min-width: 768px) {
    .v2-process-step { margin-top: 0; }
    .v2-process-step:first-child { margin-left: 0; }
  }
  .v2-process-step strong {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--color-ember);
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
  }
  .v2-process-step h4 {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .v2-process-step p {
    font-size: 0.9rem;
    color: var(--color-steel);
    line-height: 1.6;
  }
</style>
