---
import V2Layout from '../../layouts/V2Layout.astro';
---

<V2Layout title="You First Construction | Custom Home Builders" currentPage="home">

  <!-- ===== HERO: Split-screen, oversized type ===== -->
  <section class="v2-hero">
    <div class="v2-hero__text">
      <div class="v2-hero__tag">
        <span class="v2-bar"></span>
        <span>Custom Home Builders — Est. 1999</span>
      </div>
      <h1 class="v2-display">
        Your Home,<br/>Our <span class="v2-hero__em">Craft.</span>
      </h1>
      <p class="v2-hero__sub">
        New construction. Remodeling. Restoration.<br/>
        From luxury residences to commercial builds — we put you first in every decision.
      </p>
      <div class="v2-hero__ctas">
        <a href="/v2/contact" class="v2-btn v2-btn--fill">
          Start Your Project
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/v2/services" class="v2-btn">
          Our Services
        </a>
      </div>
    </div>
    <div class="v2-hero__visual">
      <div class="v2-img-placeholder v2-hero__img">
        <div class="v2-hero__img-label">Featured Project</div>
      </div>
      <!-- Overlapping stat bar -->
      <div class="v2-hero__stats">
        <div class="v2-hero__stat">
          <strong>25+</strong>
          <span>Years</span>
        </div>
        <div class="v2-hero__stat-div"></div>
        <div class="v2-hero__stat">
          <strong>500+</strong>
          <span>Projects</span>
        </div>
        <div class="v2-hero__stat-div"></div>
        <div class="v2-hero__stat">
          <strong>100%</strong>
          <span>Satisfaction</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES TEASER ===== -->
  <hr class="v2-hr" />
  <section class="v2-section">
    <div class="v2-services-teaser">
      <div class="v2-services-teaser__head">
        <span class="v2-bar"></span>
        <h2 class="v2-services-teaser__title">Two Divisions.<br/>One Standard.</h2>
        <p>Every project gets our full expertise, regardless of scale or complexity.</p>
        <a href="/v2/services" class="v2-btn" style="margin-top:1.5rem;">
          View All Services
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
      <div class="v2-services-teaser__grid">
        <div class="v2-box">
          <span class="v2-box__tag">New Construction</span>
          <div class="v2-box__title">Commercial & Residential</div>
          <div class="v2-box__desc">Full-scale new builds from office complexes to family homes.</div>
        </div>
        <div class="v2-box">
          <span class="v2-box__tag">New Construction</span>
          <div class="v2-box__title">Custom & Spec Homes</div>
          <div class="v2-box__desc">Bespoke homes tailored to your vision or built to the highest market standards.</div>
        </div>
        <div class="v2-box">
          <span class="v2-box__tag">Remodeling</span>
          <div class="v2-box__title">High-End Remodels</div>
          <div class="v2-box__desc">Luxury renovations with premium materials and design-forward thinking.</div>
        </div>
        <div class="v2-box">
          <span class="v2-box__tag">Remodeling</span>
          <div class="v2-box__title">Restoration & Recovery</div>
          <div class="v2-box__desc">Disaster recovery and structural restoration for damaged properties.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT TEASER ===== -->
  <hr class="v2-hr" />
  <section class="v2-about-teaser">
    <div class="v2-about-teaser__inner">
      <div class="v2-about-teaser__left">
        <div class="v2-img-placeholder v2-about-teaser__img"></div>
      </div>
      <div class="v2-about-teaser__right">
        <span class="v2-bar"></span>
        <h2>Building Trust<br/>Since <span style="color:var(--color-ember)">1999</span></h2>
        <p>
          Founded with a simple conviction: the best buildings come from putting people first.
          Over 25 years, we've delivered more than 500 projects across residential and commercial
          sectors — every one with the same uncompromising commitment to quality.
        </p>
        <blockquote>
          "We didn't start this company to be the biggest builder. We started it to be the one people trust most."
        </blockquote>
        <a href="/v2/about" class="v2-btn">
          Our Story
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== PROJECTS TEASER ===== -->
  <hr class="v2-hr" />
  <section class="v2-section">
    <div class="v2-projects-teaser__head">
      <span class="v2-bar"></span>
      <h2 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,3.5rem); line-height:0.95; margin-top:1rem;">Selected Work</h2>
    </div>
    <div class="v2-projects-teaser__grid">
      <a href="/v2/projects" class="v2-project-card v2-project-card--large">
        <div class="v2-img-placeholder v2-project-card__img"></div>
        <div class="v2-project-card__info">
          <span class="v2-project-card__cat">Custom Home</span>
          <h3>Coastal Modern Residence</h3>
          <span class="v2-project-card__meta">Malibu, CA — 4,200 sq ft</span>
        </div>
      </a>
      <a href="/v2/projects" class="v2-project-card">
        <div class="v2-img-placeholder v2-project-card__img"></div>
        <div class="v2-project-card__info">
          <span class="v2-project-card__cat">Commercial</span>
          <h3>Downtown Office Complex</h3>
          <span class="v2-project-card__meta">Los Angeles, CA</span>
        </div>
      </a>
      <a href="/v2/projects" class="v2-project-card">
        <div class="v2-img-placeholder v2-project-card__img"></div>
        <div class="v2-project-card__info">
          <span class="v2-project-card__cat">Restoration</span>
          <h3>Heritage Home Restoration</h3>
          <span class="v2-project-card__meta">Pasadena, CA</span>
        </div>
      </a>
    </div>
    <div style="text-align:center; margin-top:3rem;">
      <a href="/v2/projects" class="v2-btn">
        View All Projects
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- ===== CTA BAND ===== -->
  <section class="v2-cta-band">
    <div class="v2-cta-band__inner">
      <h2>Ready to Build?</h2>
      <p>Tell us about your project. We'll respond within 24 hours.</p>
      <a href="/v2/contact" class="v2-btn v2-btn--fill">
        Get a Free Quote
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

</V2Layout>

<style>
  /* ===== HOME-SPECIFIC STYLES ===== */

  /* HERO */
  .v2-hero {
    display: grid;
    grid-template-columns: 1fr;
    min-height: calc(100vh - 72px);
  }
  @media (min-width: 1024px) {
    .v2-hero { grid-template-columns: 1fr 1fr; }
  }
  .v2-hero__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 2rem;
    max-width: 720px;
    margin-left: auto;
  }
  @media (min-width: 1024px) {
    .v2-hero__text { padding: 6rem 4rem 6rem 2rem; }
  }
  .v2-hero__tag {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-charcoal-light);
    margin-bottom: 2rem;
  }
  .v2-hero__em {
    color: var(--color-ember);
    position: relative;
  }
  .v2-hero__em::after {
    content: '';
    position: absolute;
    bottom: 0.05em;
    left: 0;
    width: 100%;
    height: 5px;
    background: var(--color-ember);
    opacity: 0.3;
  }
  .v2-hero__sub {
    font-size: 1.15rem;
    color: var(--color-slate);
    line-height: 1.7;
    margin-top: 2rem;
    max-width: 480px;
  }
  .v2-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  /* Hero visual */
  .v2-hero__visual {
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .v2-hero__img {
    flex: 1;
    min-height: 350px;
  }
  @media (min-width: 1024px) {
    .v2-hero__img { min-height: unset; }
  }
  .v2-hero__img-label {
    position: absolute;
    bottom: 5rem;
    left: 2rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-ember);
    background: var(--color-charcoal-dark);
    padding: 0.5rem 1rem;
    z-index: 2;
  }

  /* Stats overlay bar */
  .v2-hero__stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    background: var(--color-ember);
    padding: 1.25rem 2rem;
  }
  .v2-hero__stat {
    text-align: center;
  }
  .v2-hero__stat strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: white;
    line-height: 1;
  }
  .v2-hero__stat span {
    font-family: var(--font-heading);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    margin-top: 0.25rem;
    display: block;
  }
  .v2-hero__stat-div {
    width: 1px;
    height: 32px;
    background: rgba(255,255,255,0.25);
  }

  /* SERVICES TEASER */
  .v2-services-teaser {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .v2-services-teaser {
      grid-template-columns: 1fr 2fr;
      gap: 4rem;
    }
  }
  .v2-services-teaser__head p {
    font-size: 1rem;
    color: var(--color-slate);
    line-height: 1.7;
    margin-top: 1rem;
    max-width: 360px;
  }
  .v2-services-teaser__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    margin-top: 1rem;
  }
  .v2-services-teaser__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 640px) {
    .v2-services-teaser__grid { grid-template-columns: 1fr 1fr; }
  }
  .v2-services-teaser__grid .v2-box {
    border-right-width: 0;
    border-bottom-width: 0;
  }
  .v2-services-teaser__grid .v2-box:nth-child(even) { border-right-width: 3px; }
  .v2-services-teaser__grid .v2-box:nth-last-child(-n+2) { border-bottom-width: 3px; }
  @media (max-width: 639px) {
    .v2-services-teaser__grid .v2-box { border-right-width: 3px; }
    .v2-services-teaser__grid .v2-box:last-child { border-bottom-width: 3px; }
  }

  /* ABOUT TEASER */
  .v2-about-teaser {
    background: var(--color-charcoal-dark);
    color: white;
  }
  .v2-about-teaser__inner {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 1024px) {
    .v2-about-teaser__inner { grid-template-columns: 1fr 1fr; }
  }
  .v2-about-teaser__img {
    min-height: 350px;
  }
  @media (min-width: 1024px) {
    .v2-about-teaser__img { min-height: 500px; }
  }
  .v2-about-teaser__right {
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media (min-width: 1024px) {
    .v2-about-teaser__right { padding: 5rem 4rem; }
  }
  .v2-about-teaser__right h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 0.95;
    margin-top: 1.25rem;
  }
  .v2-about-teaser__right p {
    font-size: 1rem;
    color: var(--color-steel);
    line-height: 1.7;
    margin-top: 1.5rem;
    max-width: 480px;
  }
  .v2-about-teaser__right blockquote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--color-ember-light);
    border-left: 4px solid var(--color-ember);
    padding-left: 1.25rem;
    margin: 2rem 0;
    line-height: 1.5;
  }
  .v2-about-teaser__right .v2-btn {
    border-color: white;
    color: white;
    align-self: flex-start;
  }
  .v2-about-teaser__right .v2-btn:hover {
    background: var(--color-ember);
    border-color: var(--color-ember);
  }

  /* PROJECTS TEASER */
  .v2-projects-teaser__head {
    margin-bottom: 2.5rem;
  }
  .v2-projects-teaser__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3px;
  }
  @media (min-width: 768px) {
    .v2-projects-teaser__grid {
      grid-template-columns: 1.4fr 1fr;
      grid-template-rows: 1fr 1fr;
    }
  }
  .v2-project-card {
    display: block;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
  }
  .v2-project-card__img {
    height: 280px;
  }
  .v2-project-card--large .v2-project-card__img {
    height: 280px;
  }
  @media (min-width: 768px) {
    .v2-project-card--large {
      grid-row: 1 / 3;
    }
    .v2-project-card--large .v2-project-card__img {
      height: 100%;
      min-height: 400px;
    }
  }
  .v2-project-card__info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem;
    background: linear-gradient(to top, rgba(42,42,42,0.95), transparent);
    color: white;
  }
  .v2-project-card__cat {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-ember);
    display: block;
    margin-bottom: 0.5rem;
  }
  .v2-project-card__info h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.1;
  }
  .v2-project-card--large .v2-project-card__info h3 {
    font-size: 2rem;
  }
  .v2-project-card__meta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--color-steel);
    margin-top: 0.4rem;
    display: block;
  }
  .v2-project-card:hover .v2-project-card__info h3 {
    color: var(--color-ember);
  }

  /* CTA BAND */
  .v2-cta-band {
    background: var(--color-ember);
    border-top: 3px solid var(--color-charcoal-dark);
  }
  .v2-cta-band__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 4rem 2rem;
    text-align: center;
  }
  .v2-cta-band h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: white;
    line-height: 1;
  }
  .v2-cta-band p {
    color: rgba(255,255,255,0.8);
    font-size: 1.1rem;
    margin: 1rem 0 2rem;
  }
  .v2-cta-band .v2-btn--fill {
    background: var(--color-charcoal-dark);
    border-color: var(--color-charcoal-dark);
  }
  .v2-cta-band .v2-btn--fill:hover {
    background: var(--color-charcoal);
    border-color: var(--color-charcoal);
  }
</style>
