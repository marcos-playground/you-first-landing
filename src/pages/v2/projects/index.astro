---
import V2Layout from '../../../layouts/V2Layout.astro';

const projects = [
  { tag: "P-01", title: "Coastal Modern Residence", category: "Custom Home", location: "Malibu, CA", sqft: "4,200 sq ft", size: "large" },
  { tag: "P-02", title: "Downtown Office Complex", category: "Commercial Build", location: "Los Angeles, CA", sqft: "12,000 sq ft", size: "normal" },
  { tag: "P-03", title: "Heritage Home Restoration", category: "Restoration", location: "Pasadena, CA", sqft: "3,800 sq ft", size: "normal" },
  { tag: "P-04", title: "Hillside Spec Home", category: "Spec Home", location: "Hollywood Hills, CA", sqft: "5,500 sq ft", size: "normal" },
  { tag: "P-05", title: "Restaurant Renovation", category: "Commercial Remodel", location: "Santa Monica, CA", sqft: "2,400 sq ft", size: "large" },
  { tag: "P-06", title: "Modern Farmhouse", category: "Custom Home", location: "Calabasas, CA", sqft: "6,100 sq ft", size: "normal" },
  { tag: "P-07", title: "Luxury Kitchen & Bath", category: "High-End Remodel", location: "Beverly Hills, CA", sqft: "1,200 sq ft", size: "normal" },
  { tag: "P-08", title: "Fire Recovery Rebuild", category: "Disaster Recovery", location: "Thousand Oaks, CA", sqft: "3,400 sq ft", size: "normal" },
];

const categories = ["All", "Custom Home", "Commercial", "Remodel", "Restoration"];
---

<V2Layout title="Projects | You First Construction" currentPage="projects">

  <!-- Page header -->
  <div class="v2-page-header">
    <div class="v2-page-header__inner">
      <div class="v2-page-header__crumb">
        <a href="/v2" style="color:var(--color-steel); text-decoration:none;">Home</a>
        <span>/</span>
        Projects
      </div>
      <h1>Selected <span style="color:var(--color-ember)">Work</span></h1>
      <p>A selection of recent builds, renovations, and restorations that showcase our range and commitment to excellence.</p>
    </div>
  </div>

  <!-- Filter bar -->
  <div class="v2-filter-bar">
    <div class="v2-filter-bar__inner">
      {categories.map((cat, i) => (
        <button class:list={['v2-filter-btn', { 'is-active': i === 0 }]}>
          {cat}
        </button>
      ))}
    </div>
  </div>

  <!-- Projects grid -->
  <section class="v2-section">
    <div class="v2-proj-grid">
      {projects.map((p) => (
        <div class:list={['v2-proj-item', { 'v2-proj-item--wide': p.size === 'large' }]}>
          <div class="v2-img-placeholder v2-proj-item__img"></div>
          <div class="v2-proj-item__info">
            <div class="v2-proj-item__top">
              <span class="v2-proj-item__tag">{p.tag}</span>
              <span class="v2-proj-item__cat">{p.category}</span>
            </div>
            <h3 class="v2-proj-item__title">{p.title}</h3>
            <div class="v2-proj-item__meta">
              <span>{p.location}</span>
              <span class="v2-proj-item__dot"></span>
              <span>{p.sqft}</span>
            </div>
            <div class="v2-proj-item__hover">
              <span class="v2-bar" style="width:32px; height:3px;"></span>
              <span>View Project</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="v2-proj-cta">
    <div class="v2-proj-cta__inner">
      <h2>Have a Project in Mind?</h2>
      <p>Let's discuss your vision. We offer free consultations for all project types.</p>
      <a href="/v2/contact" class="v2-btn v2-btn--fill">
        Start a Conversation
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

</V2Layout>

<style>
  /* Filter bar */
  .v2-filter-bar {
    border-bottom: 3px solid var(--color-charcoal-dark);
    background: var(--color-bone);
  }
  .v2-filter-bar__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    gap: 0;
    overflow-x: auto;
  }
  .v2-filter-btn {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-slate);
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.25s ease;
    margin-bottom: -3px;
  }
  .v2-filter-btn:hover { color: var(--color-charcoal-dark); }
  .v2-filter-btn.is-active {
    color: var(--color-charcoal-dark);
    border-bottom-color: var(--color-ember);
  }

  /* Projects grid */
  .v2-proj-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3px;
  }
  @media (min-width: 768px) {
    .v2-proj-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1200px) {
    .v2-proj-grid { grid-template-columns: 1fr 1fr 1fr; }
  }

  .v2-proj-item {
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }
  .v2-proj-item--wide {
    grid-column: span 1;
  }
  @media (min-width: 768px) {
    .v2-proj-item--wide { grid-column: span 2; }
  }
  .v2-proj-item__img {
    height: 320px;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .v2-proj-item--wide .v2-proj-item__img {
    height: 360px;
  }
  .v2-proj-item:hover .v2-proj-item__img {
    transform: scale(1.03);
  }

  .v2-proj-item__info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem;
    background: linear-gradient(to top, rgba(42,42,42,0.95) 0%, rgba(42,42,42,0.6) 60%, transparent 100%);
    color: white;
  }
  .v2-proj-item__top {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .v2-proj-item__tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--color-ember);
  }
  .v2-proj-item__cat {
    font-family: var(--font-heading);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-steel);
  }
  .v2-proj-item__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.1;
    transition: color 0.3s ease;
  }
  .v2-proj-item--wide .v2-proj-item__title { font-size: 2rem; }
  .v2-proj-item:hover .v2-proj-item__title { color: var(--color-ember); }
  .v2-proj-item__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: var(--color-steel);
    margin-top: 0.5rem;
  }
  .v2-proj-item__dot {
    width: 4px;
    height: 4px;
    background: var(--color-ember);
    border-radius: 50%;
    display: inline-block;
  }
  .v2-proj-item__hover {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ember);
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .v2-proj-item:hover .v2-proj-item__hover {
    opacity: 1;
    transform: translateY(0);
  }

  /* CTA */
  .v2-proj-cta {
    background: var(--color-ember);
    border-top: 3px solid var(--color-charcoal-dark);
  }
  .v2-proj-cta__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 4rem 2rem;
    text-align: center;
  }
  .v2-proj-cta h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: white;
    line-height: 1;
  }
  .v2-proj-cta p {
    color: rgba(255,255,255,0.8);
    font-size: 1.1rem;
    margin: 1rem 0 2rem;
  }
  .v2-proj-cta .v2-btn--fill {
    background: var(--color-charcoal-dark);
    border-color: var(--color-charcoal-dark);
  }
  .v2-proj-cta .v2-btn--fill:hover {
    background: var(--color-charcoal);
    border-color: var(--color-charcoal);
  }
</style>
