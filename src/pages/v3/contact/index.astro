---
import V3Layout from '../../../layouts/V3Layout.astro';
---

<V3Layout
  title="Contact | You First Construction"
  description="Get in touch with You First Construction for a free consultation on your next construction or remodeling project."
  currentPage="contact"
>
  <!-- ===================== HERO ===================== -->
  <section class="v3-page-hero v3-bg-dark v3-texture">
    <div class="v3-container">
      <nav class="v3-breadcrumb v3-reveal" aria-label="Breadcrumb">
        <a href="/v3">Home</a>
        <span class="v3-breadcrumb-sep">/</span>
        <span class="v3-breadcrumb-current">Contact</span>
      </nav>
      <div class="v3-badge v3-badge-light v3-reveal">Get in Touch</div>
      <h1 class="v3-display v3-display-xl v3-reveal v3-reveal-d1" style="margin-top: 1rem;">
        Let us build something<br />together.
      </h1>
      <div class="v3-ember-bar v3-reveal v3-reveal-d2" style="margin-top: 1.25rem;"></div>
      <p class="v3-text v3-reveal v3-reveal-d3" style="max-width: 520px; margin-top: 1rem;">
        Whether you are ready to start or just exploring options, we are here to help. Reach out and we will get back to you within one business day.
      </p>
    </div>
  </section>

  <!-- ===================== FORM + INFO ===================== -->
  <section class="v3-section" style="padding-top: 3rem;">
    <div class="v3-container">
      <div class="v3-contact-grid">
        <!-- Form -->
        <div class="v3-contact-form-wrap v3-reveal">
          <h2 class="v3-form-heading">Send us a message</h2>
          <p class="v3-form-subhead">Fill out the form below and our team will respond within 24 hours.</p>

          <form class="v3-form" action="#" method="post">
            <div class="v3-form-row">
              <div class="v3-form-group">
                <label for="firstName" class="v3-form-label">First Name</label>
                <input type="text" id="firstName" name="firstName" required class="v3-form-input" placeholder="John" />
              </div>
              <div class="v3-form-group">
                <label for="lastName" class="v3-form-label">Last Name</label>
                <input type="text" id="lastName" name="lastName" required class="v3-form-input" placeholder="Doe" />
              </div>
            </div>

            <div class="v3-form-group">
              <label for="email" class="v3-form-label">Email</label>
              <input type="email" id="email" name="email" required class="v3-form-input" placeholder="john@example.com" />
            </div>

            <div class="v3-form-group">
              <label for="phone" class="v3-form-label">Phone</label>
              <input type="tel" id="phone" name="phone" class="v3-form-input" placeholder="(555) 123-4567" />
            </div>

            <div class="v3-form-group">
              <label for="projectType" class="v3-form-label">Project Type</label>
              <select id="projectType" name="projectType" required class="v3-form-input v3-form-select">
                <option value="" disabled selected>Select a project type</option>
                <option value="custom-home">Custom Home</option>
                <option value="spec-home">Spec Home</option>
                <option value="commercial">Commercial Construction</option>
                <option value="residential-remodel">Residential Remodel</option>
                <option value="commercial-remodel">Commercial Remodel</option>
                <option value="restoration">Restoration / Disaster Recovery</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="v3-form-group">
              <label for="message" class="v3-form-label">Tell us about your project</label>
              <textarea id="message" name="message" rows="5" required class="v3-form-input v3-form-textarea" placeholder="Describe your project, timeline, budget range, and any other details..."></textarea>
            </div>

            <button type="submit" class="v3-btn v3-btn-primary" style="width: 100%;">
              Send Message
            </button>
          </form>
        </div>

        <!-- Info sidebar -->
        <div class="v3-contact-sidebar">
          <div class="v3-info-card v3-reveal v3-reveal-d1">
            <div class="v3-info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <h4 class="v3-info-title">Phone</h4>
              <p class="v3-info-value">(555) 012-3456</p>
              <p class="v3-info-note">Mon - Fri, 8am - 6pm</p>
            </div>
          </div>

          <div class="v3-info-card v3-reveal v3-reveal-d2">
            <div class="v3-info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <h4 class="v3-info-title">Email</h4>
              <p class="v3-info-value">info@youfirstconstruction.com</p>
              <p class="v3-info-note">We respond within 24 hours</p>
            </div>
          </div>

          <div class="v3-info-card v3-reveal v3-reveal-d3">
            <div class="v3-info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <div>
              <h4 class="v3-info-title">Office</h4>
              <p class="v3-info-value">Houston, TX</p>
              <p class="v3-info-note">Serving the Greater Houston Area</p>
            </div>
          </div>

          <div class="v3-info-card v3-reveal v3-reveal-d4">
            <div class="v3-info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <h4 class="v3-info-title">Hours</h4>
              <p class="v3-info-value">Mon - Fri: 8am - 6pm</p>
              <p class="v3-info-note">Sat: 9am - 2pm</p>
            </div>
          </div>

          <!-- Service area block (replaces "Map Coming Soon") -->
          <div class="v3-service-area v3-reveal v3-reveal-d5">
            <div class="v3-service-area-inner v3-texture">
              <h4 class="v3-sa-heading">Service Area</h4>
              <div class="v3-sa-list">
                <div class="v3-sa-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="10" r="2" stroke="currentColor" stroke-width="2"/></svg>
                  Houston Metro
                </div>
                <div class="v3-sa-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="10" r="2" stroke="currentColor" stroke-width="2"/></svg>
                  Sugar Land
                </div>
                <div class="v3-sa-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="10" r="2" stroke="currentColor" stroke-width="2"/></svg>
                  The Woodlands
                </div>
                <div class="v3-sa-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="10" r="2" stroke="currentColor" stroke-width="2"/></svg>
                  Katy
                </div>
                <div class="v3-sa-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="10" r="2" stroke="currentColor" stroke-width="2"/></svg>
                  Pearland
                </div>
                <div class="v3-sa-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="10" r="2" stroke="currentColor" stroke-width="2"/></svg>
                  Galveston County
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</V3Layout>

<style>
  /* ===================== CONTACT GRID ===================== */
  .v3-contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 860px) {
    .v3-contact-grid { grid-template-columns: 1.3fr 1fr; gap: 4rem; }
  }

  /* ===================== FORM ===================== */
  .v3-contact-form-wrap {
    background: white;
    border: 1px solid rgba(42, 42, 42, 0.1);
    border-radius: var(--v3-radius-lg);
    padding: 2.5rem 2rem;
  }

  .v3-form-heading {
    font-family: var(--v3-font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--v3-charcoal);
    margin-bottom: 0.25rem;
  }

  .v3-form-subhead {
    font-size: 0.9375rem;
    color: var(--v3-charcoal-light);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .v3-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .v3-form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 480px) {
    .v3-form-row { grid-template-columns: 1fr 1fr; }
  }

  .v3-form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .v3-form-label {
    font-family: var(--v3-font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--v3-charcoal);
    letter-spacing: 0.01em;
  }

  .v3-form-input {
    font-family: var(--v3-font-body);
    font-size: 0.9375rem;
    color: var(--v3-charcoal);
    background: var(--v3-white);
    border: 1px solid rgba(42, 42, 42, 0.12);
    border-radius: var(--v3-radius);
    padding: 0.75rem 1rem;
    transition: border-color 0.25s var(--v3-ease), box-shadow 0.25s var(--v3-ease);
    outline: none;
    width: 100%;
  }

  .v3-form-input::placeholder {
    color: var(--v3-stone);
  }

  .v3-form-input:focus {
    border-color: var(--v3-ember);
    box-shadow: 0 0 0 3px rgba(232, 97, 26, 0.1);
  }

  .v3-form-select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%235A5A5A' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
  }

  .v3-form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* ===================== INFO CARDS ===================== */
  .v3-contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .v3-info-card {
    background: white;
    border: 1px solid rgba(42, 42, 42, 0.1);
    border-radius: var(--v3-radius-lg);
    padding: 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    transition: border-color 0.3s;
  }

  .v3-info-card:hover {
    border-color: rgba(232, 97, 26, 0.2);
  }

  .v3-info-icon {
    width: 44px;
    height: 44px;
    min-width: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--v3-cream);
    border-radius: var(--v3-radius);
    color: var(--v3-ember);
  }

  .v3-info-title {
    font-family: var(--v3-font-body);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--v3-stone);
    margin-bottom: 0.125rem;
  }

  .v3-info-value {
    font-family: var(--v3-font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--v3-charcoal);
  }

  .v3-info-note {
    font-size: 0.8125rem;
    color: var(--v3-stone);
    margin-top: 0.125rem;
  }

  /* ===================== SERVICE AREA ===================== */
  .v3-service-area {
    border-radius: var(--v3-radius-lg);
    overflow: hidden;
  }

  .v3-service-area-inner {
    background: var(--v3-charcoal);
    padding: 2rem;
    position: relative;
    border-radius: var(--v3-radius-lg);
  }

  .v3-sa-heading {
    font-family: var(--v3-font-body);
    font-size: 0.8125rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--v3-ember);
    margin-bottom: 1.25rem;
  }

  .v3-sa-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .v3-sa-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.65);
  }

  .v3-sa-item svg {
    color: var(--v3-ember);
    flex-shrink: 0;
  }
</style>
