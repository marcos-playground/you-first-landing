---
import V3Layout from '../../layouts/V3Layout.astro';
---

<V3Layout
  title="You First Construction | Custom Home Builders in Houston"
  description="Premium custom home construction, remodeling, and restoration. We put you first — from blueprint to move-in day."
  currentPage="home"
>
  <!-- ===================== HERO — Full-bleed dark with ember accent ===================== -->
  <section class="v3-hero v3-texture">
    <div class="v3-hero-inner">
      <div class="v3-hero-content">
        <div class="v3-badge v3-badge-light v3-reveal">Houston's Trusted Builder</div>

        <h1 class="v3-display v3-display-xl v3-hero-heading v3-reveal v3-reveal-d1">
          We build homes that put&nbsp;you&nbsp;first.
        </h1>

        <div class="v3-ember-bar v3-reveal v3-reveal-d2"></div>

        <p class="v3-hero-desc v3-reveal v3-reveal-d3">
          From custom homes and commercial builds to full-scale remodels and disaster recovery, You First Construction delivers quality craftsmanship with a personal touch.
        </p>

        <div class="v3-hero-actions v3-reveal v3-reveal-d4">
          <a href="/v3/contact" class="v3-btn v3-btn-primary">Start Your Project</a>
          <a href="/v3/projects" class="v3-btn v3-btn-outline-light">View Our Work</a>
        </div>
      </div>

      <!-- Hero image area -->
      <div class="v3-hero-visual v3-reveal v3-reveal-d2">
        <div class="v3-hero-img-wrap">
          <div class="v3-img-placeholder"></div>
          <!-- Ember corner accent -->
          <div class="v3-hero-corner"></div>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="v3-hero-stats v3-reveal v3-reveal-d5">
      <div class="v3-stat">
        <span class="v3-stat-num">25+</span>
        <span class="v3-stat-label">Years of Experience</span>
      </div>
      <div class="v3-stat">
        <span class="v3-stat-num">500+</span>
        <span class="v3-stat-label">Projects Completed</span>
      </div>
      <div class="v3-stat">
        <span class="v3-stat-num">100%</span>
        <span class="v3-stat-label">Client Satisfaction</span>
      </div>
      <div class="v3-stat">
        <span class="v3-stat-num">60+</span>
        <span class="v3-stat-label">Team Members</span>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section class="v3-section">
    <div class="v3-container">
      <div class="v3-split-header">
        <div>
          <div class="v3-badge v3-reveal">What We Do</div>
          <h2 class="v3-display v3-display-lg v3-reveal v3-reveal-d1" style="margin-top: 1rem;">
            Full-spectrum<br />construction services.
          </h2>
        </div>
        <div class="v3-reveal v3-reveal-d2">
          <p class="v3-text">
            Whether you're dreaming of a new custom home or revitalizing an existing space, we bring decades of expertise and genuine care to every project.
          </p>
          <div style="margin-top: 1.5rem;">
            <a href="/v3/services" class="v3-btn v3-btn-outline">Explore All Services</a>
          </div>
        </div>
      </div>

      <div class="v3-services-grid">
        <a href="/v3/services" class="v3-svc-card v3-reveal v3-reveal-d1">
          <div class="v3-svc-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 2L1 12h3v13h8v-7h4v7h8V12h3L14 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="v3-svc-title">New Construction</h3>
          <p class="v3-svc-desc">Custom homes, spec builds, commercial projects, and shell construction from the ground up.</p>
          <span class="v3-svc-link">Learn more &rarr;</span>
        </a>

        <a href="/v3/services" class="v3-svc-card v3-reveal v3-reveal-d2">
          <div class="v3-svc-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M18 5l5 5-13 13H5v-5L18 5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3 class="v3-svc-title">Remodeling</h3>
          <p class="v3-svc-desc">Residential and commercial transformations, from high-end renovations to complete overhauls.</p>
          <span class="v3-svc-link">Learn more &rarr;</span>
        </a>

        <a href="/v3/services" class="v3-svc-card v3-reveal v3-reveal-d3">
          <div class="v3-svc-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 26V10l10-7 10 7v16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 26h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="14" cy="16" r="3" stroke="currentColor" stroke-width="1.5"/></svg>
          </div>
          <h3 class="v3-svc-title">Restoration</h3>
          <p class="v3-svc-desc">Disaster recovery and property restoration — rebuilding what matters when you need it most.</p>
          <span class="v3-svc-link">Learn more &rarr;</span>
        </a>

        <a href="/v3/services" class="v3-svc-card v3-reveal v3-reveal-d4">
          <div class="v3-svc-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="3" y="6" width="22" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M9 6V3h10v3M9 14h3m4 0h3M9 20h3m4 0h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3 class="v3-svc-title">Commercial</h3>
          <p class="v3-svc-desc">Office, retail, and mixed-use projects delivered on time and on budget with commercial-grade quality.</p>
          <span class="v3-svc-link">Learn more &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== PROJECTS (dark section) ===================== -->
  <section class="v3-section v3-bg-dark v3-texture">
    <div class="v3-container">
      <div class="v3-section-header-center v3-reveal">
        <div class="v3-badge v3-badge-light">Our Work</div>
        <h2 class="v3-display v3-display-lg" style="margin-top: 1rem;">
          Craftsmanship you can see.
        </h2>
      </div>

      <div class="v3-projects-mosaic">
        <div class="v3-mosaic-item v3-mosaic-wide v3-reveal v3-reveal-d1">
          <div class="v3-mosaic-img"><div class="v3-img-placeholder"></div></div>
          <div class="v3-mosaic-info">
            <span class="v3-mosaic-cat">Custom Home</span>
            <h3 class="v3-mosaic-title">Riverstone Estate</h3>
            <span class="v3-mosaic-meta">Sugar Land, TX &mdash; 4,800 sq ft</span>
          </div>
        </div>
        <div class="v3-mosaic-item v3-reveal v3-reveal-d2">
          <div class="v3-mosaic-img"><div class="v3-img-placeholder"></div></div>
          <div class="v3-mosaic-info">
            <span class="v3-mosaic-cat">Remodel</span>
            <h3 class="v3-mosaic-title">Heights Kitchen Renovation</h3>
          </div>
        </div>
        <div class="v3-mosaic-item v3-reveal v3-reveal-d3">
          <div class="v3-mosaic-img"><div class="v3-img-placeholder"></div></div>
          <div class="v3-mosaic-info">
            <span class="v3-mosaic-cat">Commercial</span>
            <h3 class="v3-mosaic-title">Midtown Office Complex</h3>
          </div>
        </div>
      </div>

      <div style="text-align: center; margin-top: 3rem;" class="v3-reveal v3-reveal-d4">
        <a href="/v3/projects" class="v3-btn v3-btn-primary">View All Projects</a>
      </div>
    </div>
  </section>

  <!-- ===================== ABOUT PREVIEW ===================== -->
  <section class="v3-section v3-bg-cream v3-texture">
    <div class="v3-container">
      <div class="v3-about-split">
        <div class="v3-about-left v3-reveal">
          <div class="v3-badge">About Us</div>
          <h2 class="v3-display v3-display-lg" style="margin-top: 1rem;">
            Built on trust.<br />Driven by quality.
          </h2>
          <div class="v3-ember-bar" style="margin-top: 1.25rem;"></div>
          <p class="v3-text" style="margin-top: 1.25rem;">
            For over two decades, You First Construction has been the name Houston homeowners and businesses trust for quality craftsmanship and transparent communication.
          </p>
          <p class="v3-text" style="margin-top: 0.75rem;">
            We don't just build structures — we build relationships that last.
          </p>
          <div style="margin-top: 2rem;">
            <a href="/v3/about" class="v3-btn v3-btn-dark">Our Story</a>
          </div>
        </div>

        <div class="v3-about-right">
          <div class="v3-about-values-stack">
            <div class="v3-val-item v3-card v3-reveal v3-reveal-d1">
              <div class="v3-val-num">01</div>
              <div>
                <h4 class="v3-val-title">Integrity First</h4>
                <p class="v3-val-desc">Honest communication, transparent pricing, and promises kept — every single time.</p>
              </div>
            </div>
            <div class="v3-val-item v3-card v3-reveal v3-reveal-d2">
              <div class="v3-val-num">02</div>
              <div>
                <h4 class="v3-val-title">Expert Craftsmanship</h4>
                <p class="v3-val-desc">Every detail matters — from foundation to finish, we never cut corners.</p>
              </div>
            </div>
            <div class="v3-val-item v3-card v3-reveal v3-reveal-d3">
              <div class="v3-val-num">03</div>
              <div>
                <h4 class="v3-val-title">True Partnership</h4>
                <p class="v3-val-desc">Your vision drives our work. We collaborate closely from first sketch to final walkthrough.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="v3-cta-band">
    <div class="v3-container v3-reveal">
      <div class="v3-cta-content">
        <h2 class="v3-display v3-display-lg" style="color: white;">
          Ready to start building?
        </h2>
        <p class="v3-cta-desc">
          Let's discuss your vision. Whether it's a new home, renovation, or commercial project — we're here to make it happen.
        </p>
      </div>
      <div class="v3-cta-actions">
        <a href="/v3/contact" class="v3-btn v3-btn-white">Get a Free Consultation</a>
        <a href="tel:5550123456" class="v3-cta-phone">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          (555) 012-3456
        </a>
      </div>
    </div>
  </section>
</V3Layout>

<style>
  /* ===================== HERO ===================== */
  .v3-hero {
    background: var(--v3-charcoal);
    color: white;
    padding: 8rem 1.5rem 0;
    position: relative;
    overflow: hidden;
  }

  .v3-hero::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    height: 100%;
    background: radial-gradient(ellipse at 80% 40%, rgba(232, 97, 26, 0.1) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  @media (min-width: 768px) {
    .v3-hero { padding: 10rem 2rem 0; }
  }

  .v3-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  @media (min-width: 960px) {
    .v3-hero-inner {
      grid-template-columns: 1.15fr 1fr;
      gap: 4rem;
    }
  }

  .v3-hero-heading { color: white; }

  .v3-hero-desc {
    font-size: 1.125rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.7);
    max-width: 520px;
    margin-top: 1.5rem;
  }

  .v3-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }

  .v3-btn-outline-light {
    color: white;
    background: transparent;
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .v3-btn-outline-light:hover {
    border-color: white;
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-2px);
  }

  /* Hero image */
  .v3-hero-visual { position: relative; }

  .v3-hero-img-wrap {
    border-radius: var(--v3-radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    position: relative;
  }

  .v3-hero-corner {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 80px;
    height: 80px;
    background: var(--v3-ember);
    clip-path: polygon(100% 0, 100% 100%, 0 100%);
    z-index: 3;
  }

  /* Stats */
  .v3-hero-stats {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: rgba(255, 255, 255, 0.04);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin-top: 4rem;
    position: relative;
    z-index: 2;
  }

  @media (min-width: 640px) {
    .v3-hero-stats {
      grid-template-columns: 1fr 1fr 1fr 1fr;
    }
  }

  .v3-stat {
    padding: 2rem 1.5rem;
    text-align: center;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .v3-stat:last-child { border-right: none; }

  @media (min-width: 640px) {
    .v3-stat { border-bottom: none; }
  }

  .v3-stat-num {
    display: block;
    font-family: var(--v3-font-display);
    font-size: 2.75rem;
    font-weight: 800;
    color: var(--v3-ember);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .v3-stat-label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.45);
    margin-top: 0.5rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ===================== SERVICES ===================== */
  .v3-split-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3.5rem;
  }

  @media (min-width: 768px) {
    .v3-split-header {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: end;
    }
  }

  .v3-services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .v3-services-grid { grid-template-columns: 1fr 1fr; }
  }

  .v3-svc-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    text-decoration: none;
    color: inherit;
    background: white;
    border: 1px solid rgba(42, 42, 42, 0.1);
    border-radius: var(--v3-radius-lg);
    padding: 2rem;
    transition: all 0.4s var(--v3-ease);
    position: relative;
    overflow: hidden;
  }

  .v3-svc-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 0;
    background: var(--v3-ember);
    border-radius: 0 0 2px 0;
    transition: height 0.4s var(--v3-ease);
  }

  .v3-svc-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 60px -12px rgba(42, 42, 42, 0.15);
    border-color: rgba(232, 97, 26, 0.25);
  }

  .v3-svc-card:hover::before { height: 100%; }

  .v3-svc-icon-wrap {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--v3-cream);
    border-radius: var(--v3-radius);
    color: var(--v3-ember);
  }

  .v3-svc-title {
    font-family: var(--v3-font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--v3-charcoal);
  }

  .v3-svc-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--v3-charcoal-light);
    flex: 1;
  }

  .v3-svc-link {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--v3-ember);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.3s, transform 0.3s var(--v3-ease);
  }

  .v3-svc-card:hover .v3-svc-link {
    opacity: 1;
    transform: translateX(0);
  }

  /* ===================== PROJECTS (dark) ===================== */
  .v3-section-header-center {
    text-align: center;
    margin-bottom: 3rem;
  }

  .v3-projects-mosaic {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .v3-projects-mosaic {
      grid-template-columns: 1.3fr 1fr;
      grid-template-rows: 1fr 1fr;
    }

    .v3-mosaic-wide {
      grid-row: 1 / 3;
    }
  }

  .v3-mosaic-item {
    position: relative;
    border-radius: var(--v3-radius-lg);
    overflow: hidden;
    cursor: pointer;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .v3-mosaic-img {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .v3-mosaic-wide .v3-mosaic-img {
    aspect-ratio: auto;
    position: absolute;
    inset: 0;
  }

  .v3-mosaic-wide {
    min-height: 380px;
  }

  @media (min-width: 768px) {
    .v3-mosaic-wide { min-height: 440px; }
  }

  .v3-mosaic-item .v3-img-placeholder {
    transition: transform 0.6s var(--v3-ease);
  }

  .v3-mosaic-item:hover .v3-img-placeholder {
    transform: scale(1.04);
  }

  .v3-mosaic-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(42, 42, 42, 0.85) 0%, rgba(42, 42, 42, 0.4) 60%, transparent 100%);
    z-index: 2;
  }

  .v3-mosaic-cat {
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--v3-ember-light);
  }

  .v3-mosaic-title {
    font-family: var(--v3-font-display);
    font-size: 1.375rem;
    font-weight: 600;
    color: white;
    margin-top: 0.25rem;
  }

  .v3-mosaic-meta {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.25rem;
  }

  /* ===================== ABOUT ===================== */
  .v3-about-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 860px) {
    .v3-about-split {
      grid-template-columns: 1.1fr 1fr;
      gap: 4rem;
    }
  }

  .v3-about-values-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .v3-val-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .v3-val-num {
    font-family: var(--v3-font-display);
    font-size: 2rem;
    font-weight: 800;
    color: var(--v3-ember);
    line-height: 1;
    flex-shrink: 0;
    min-width: 48px;
  }

  .v3-val-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--v3-charcoal);
    margin-bottom: 0.25rem;
  }

  .v3-val-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--v3-charcoal-light);
  }
</style>
