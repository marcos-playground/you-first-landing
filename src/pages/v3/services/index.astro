---
import V3Layout from '../../../layouts/V3Layout.astro';

const newConstruction = [
  {
    title: 'Custom Homes',
    desc: 'Your dream home, designed and built from scratch. We work with you and your architect to bring every detail to life — from floor plan to finishing touches.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 2L1 12h3v13h8v-7h4v7h8V12h3L14 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Spec Homes',
    desc: 'Move-in ready homes built with the same quality as our custom projects. Premium finishes, thoughtful layouts, and modern design standards.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="3" y="6" width="22" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M3 12h22M9 6v18M19 6v18" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
  {
    title: 'Commercial Construction',
    desc: 'Office buildings, retail spaces, and mixed-use developments — delivered on time and on budget with commercial-grade quality.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="3" y="4" width="22" height="20" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M9 4V1h10v3M9 12h3m4 0h3M9 18h3m4 0h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Shell Construction',
    desc: 'Structural shells ready for your interior build-out. Ideal for commercial tenants or investors seeking flexibility in finishing.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M5 26V10l9-7 9 7v16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 26h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M10 18h8M10 22h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="2 3"/></svg>`,
  },
];

const remodeling = [
  {
    title: 'Residential Remodeling',
    desc: 'Kitchen and bath renovations, room additions, whole-home remodels — transforming your existing space into something extraordinary.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M18 5l5 5-13 13H5v-5L18 5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Commercial Remodeling',
    desc: 'Tenant improvements, office refreshes, and retail renovations that minimize disruption while maximizing impact.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="3" y="8" width="22" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M14 8V5M3 16h22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'High-End Renovations',
    desc: 'Luxury upgrades with premium materials, custom millwork, and meticulous attention to detail for discerning homeowners.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3l3 6 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1 3-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Restoration & Disaster Recovery',
    desc: "When the unexpected happens, we are here. Fire, flood, and storm damage repair — restoring your property and your peace of mind.",
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3C8 10 4 14 4 19a10 10 0 0020 0c0-5-4-9-10-16z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
];

const process = [
  { step: '01', title: 'Consultation', desc: 'We listen to your vision, assess your needs, and discuss timelines and budget.' },
  { step: '02', title: 'Design & Planning', desc: 'Collaborate with architects and designers to finalize blueprints and material selections.' },
  { step: '03', title: 'Construction', desc: 'Our skilled team brings plans to life with regular updates and transparent communication.' },
  { step: '04', title: 'Walkthrough & Delivery', desc: 'Final inspection, punch list review, and handover — your project, complete and perfect.' },
];
---

<V3Layout
  title="Services | You First Construction"
  description="New construction, remodeling, commercial builds, and disaster restoration services from You First Construction."
  currentPage="services"
>
  <!-- ===================== PAGE HERO — dark ===================== -->
  <section class="v3-page-hero v3-bg-dark v3-texture">
    <div class="v3-container">
      <nav class="v3-breadcrumb v3-reveal" aria-label="Breadcrumb">
        <a href="/v3">Home</a>
        <span class="v3-breadcrumb-sep">/</span>
        <span class="v3-breadcrumb-current">Services</span>
      </nav>

      <div class="v3-badge v3-badge-light v3-reveal">Our Services</div>
      <h1 class="v3-display v3-display-xl v3-reveal v3-reveal-d1" style="margin-top: 1rem;">
        Everything you need<br />under one roof.
      </h1>
      <div class="v3-ember-bar v3-reveal v3-reveal-d2" style="margin-top: 1.25rem;"></div>
      <p class="v3-text v3-reveal v3-reveal-d3" style="max-width: 560px; margin-top: 1rem;">
        From ground-up construction to complete remodels and disaster recovery, we bring the expertise and care to every project.
      </p>
    </div>
  </section>

  <!-- ===================== NEW CONSTRUCTION ===================== -->
  <section class="v3-section v3-bg-cream v3-texture">
    <div class="v3-container">
      <div class="v3-svc-section-intro v3-reveal">
        <span class="v3-label">New Construction</span>
        <h2 class="v3-display v3-display-lg" style="margin-top: 0.5rem;">Building from the ground up.</h2>
        <p class="v3-text" style="max-width: 540px; margin-top: 0.75rem;">
          Whether it is a custom family home or a commercial facility, we handle every phase of new construction with precision and pride.
        </p>
      </div>

      <div class="v3-svc-grid">
        {newConstruction.map((svc, i) => (
          <div class={`v3-svc-card-page v3-reveal v3-reveal-d${i + 1}`}>
            <div class="v3-svc-icon-wrap" set:html={svc.icon} />
            <div class="v3-svc-card-body">
              <h3 class="v3-svc-name">{svc.title}</h3>
              <p class="v3-svc-desc">{svc.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== REMODELING ===================== -->
  <section class="v3-section">
    <div class="v3-container">
      <div class="v3-svc-section-intro v3-reveal">
        <span class="v3-label">Remodeling & Restoration</span>
        <h2 class="v3-display v3-display-lg" style="margin-top: 0.5rem;">Transforming existing spaces.</h2>
        <p class="v3-text" style="max-width: 540px; margin-top: 0.75rem;">
          From luxury kitchen renovations to disaster recovery rebuilds, we approach every remodel with the same care as new construction.
        </p>
      </div>

      <div class="v3-svc-grid">
        {remodeling.map((svc, i) => (
          <div class={`v3-svc-card-page v3-reveal v3-reveal-d${i + 1}`}>
            <div class="v3-svc-icon-wrap" set:html={svc.icon} />
            <div class="v3-svc-card-body">
              <h3 class="v3-svc-name">{svc.title}</h3>
              <p class="v3-svc-desc">{svc.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== PROCESS ===================== -->
  <section class="v3-section v3-bg-dark v3-texture">
    <div class="v3-container">
      <div style="text-align: center;" class="v3-reveal">
        <div class="v3-badge v3-badge-light">Our Process</div>
        <h2 class="v3-display v3-display-lg" style="margin-top: 1rem;">How we work with you.</h2>
      </div>

      <div class="v3-process-grid">
        {process.map((p, i) => (
          <div class={`v3-process-step v3-reveal v3-reveal-d${i + 1}`}>
            <div class="v3-process-num">{p.step}</div>
            <div class="v3-process-line"></div>
            <h3 class="v3-process-title">{p.title}</h3>
            <p class="v3-process-desc">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== CTA BAND ===================== -->
  <section class="v3-cta-band">
    <div class="v3-container v3-reveal">
      <div class="v3-cta-content">
        <h2 class="v3-display v3-display-lg" style="color: white;">
          Ready to discuss your project?
        </h2>
        <p class="v3-cta-desc">
          We offer free consultations to understand your needs and provide a transparent estimate. No pressure, no hidden fees.
        </p>
      </div>
      <div class="v3-cta-actions">
        <a href="/v3/contact" class="v3-btn v3-btn-white">Request a Consultation</a>
        <a href="tel:5550123456" class="v3-cta-phone">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          (555) 012-3456
        </a>
      </div>
    </div>
  </section>
</V3Layout>

<style>
  /* ===================== SERVICE CARDS ===================== */
  .v3-svc-section-intro {
    margin-bottom: 2.5rem;
  }

  .v3-svc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .v3-svc-grid { grid-template-columns: 1fr 1fr; }
  }

  .v3-svc-card-page {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: white;
    border: 1px solid rgba(42, 42, 42, 0.1);
    border-radius: var(--v3-radius-lg);
    padding: 2rem;
    transition: all 0.4s var(--v3-ease);
    position: relative;
    overflow: hidden;
  }

  .v3-svc-card-page::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--v3-ember);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--v3-ease);
  }

  .v3-svc-card-page:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px -8px rgba(42, 42, 42, 0.12);
    border-color: rgba(232, 97, 26, 0.2);
  }

  .v3-svc-card-page:hover::before {
    transform: scaleX(1);
  }

  .v3-svc-card-page .v3-svc-icon-wrap {
    width: 52px;
    height: 52px;
    min-width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--v3-cream);
    border-radius: var(--v3-radius);
    color: var(--v3-ember);
  }

  .v3-svc-name {
    font-family: var(--v3-font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--v3-charcoal);
    margin-bottom: 0.375rem;
  }

  .v3-svc-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--v3-charcoal-light);
  }

  /* ===================== PROCESS ===================== */
  .v3-process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 3rem;
  }

  @media (min-width: 640px) {
    .v3-process-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 960px) {
    .v3-process-grid { grid-template-columns: 1fr 1fr 1fr 1fr; }
  }

  .v3-process-step {
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--v3-radius-lg);
    transition: border-color 0.3s, background 0.3s;
  }

  .v3-process-step:hover {
    border-color: rgba(232, 97, 26, 0.3);
    background: rgba(255, 255, 255, 0.06);
  }

  .v3-process-num {
    font-family: var(--v3-font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--v3-ember);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .v3-process-line {
    width: 32px;
    height: 3px;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 2px;
    margin: 0 auto 1rem;
  }

  .v3-process-title {
    font-family: var(--v3-font-body);
    font-size: 1.0625rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.5rem;
  }

  .v3-process-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.55);
  }
</style>
