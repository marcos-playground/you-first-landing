---
import V3Layout from '../../../layouts/V3Layout.astro';

const values = [
  {
    num: '01',
    title: 'Client First',
    desc: "Every decision we make starts with what is best for you. Your vision, your timeline, your budget — we respect all three.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    num: '02',
    title: 'Quality Craftsmanship',
    desc: 'We never cut corners. From materials to methods, excellence is our standard on every project we touch.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2l3 6 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1 3-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    num: '03',
    title: 'Transparent Communication',
    desc: "No surprises, no hidden costs. You always know where your project stands and what comes next.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    num: '04',
    title: 'Community Roots',
    desc: 'We live and work in the communities we build. Our reputation is our most valuable asset.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    num: '05',
    title: 'Safety & Compliance',
    desc: 'Licensed, insured, and code-compliant. We build to last and build to code — every single time.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    num: '06',
    title: 'Innovation',
    desc: 'Modern building techniques, sustainable materials, and smart home integration — we stay ahead of the curve.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 18h6M10 22h4M12 2a7 7 0 00-3 13.33V18h6v-2.67A7 7 0 0012 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
];

const milestones = [
  { year: '2000', event: 'Founded You First Construction in Houston, TX with a small crew and a big vision.' },
  { year: '2005', event: 'Completed our 50th custom home and expanded into commercial construction.' },
  { year: '2010', event: 'Launched our restoration division after helping families recover from Hurricane Ike.' },
  { year: '2015', event: 'Surpassed 300 completed projects and earned our first industry award.' },
  { year: '2020', event: 'Navigated the pandemic while maintaining zero project delays through innovative scheduling.' },
  { year: 'Today', event: '500+ projects completed, a team of 60+ professionals, and the same commitment to putting you first.' },
];
---

<V3Layout
  title="About | You First Construction"
  description="Learn about You First Construction — our history, values, mission, and the team behind 25+ years of quality construction."
  currentPage="about"
>
  <!-- ===================== HERO ===================== -->
  <section class="v3-page-hero v3-bg-dark v3-texture">
    <div class="v3-container">
      <nav class="v3-breadcrumb v3-reveal" aria-label="Breadcrumb">
        <a href="/v3">Home</a>
        <span class="v3-breadcrumb-sep">/</span>
        <span class="v3-breadcrumb-current">About</span>
      </nav>

      <div class="v3-about-hero-grid">
        <div class="v3-about-hero-text">
          <div class="v3-badge v3-badge-light v3-reveal">About Us</div>
          <h1 class="v3-display v3-display-xl v3-reveal v3-reveal-d1" style="margin-top: 1rem;">
            Putting you first<br />since 2000.
          </h1>
          <div class="v3-ember-bar v3-reveal v3-reveal-d2" style="margin-top: 1.25rem;"></div>
          <p class="v3-text v3-reveal v3-reveal-d3" style="max-width: 500px; margin-top: 1.25rem;">
            What started as a small crew with a commitment to quality has grown into one of Houston's most trusted construction firms — without ever losing sight of what matters most: you.
          </p>
        </div>

        <div class="v3-about-hero-img v3-reveal v3-reveal-d2">
          <div class="v3-about-hero-img-inner">
            <div class="v3-img-placeholder"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== STATS BAND ===================== -->
  <section class="v3-about-stats v3-bg-dark">
    <div class="v3-container">
      <div class="v3-stats-band v3-reveal">
        <div class="v3-stat">
          <span class="v3-stat-num">25+</span>
          <span class="v3-stat-label">Years of Experience</span>
        </div>
        <div class="v3-stat">
          <span class="v3-stat-num">500+</span>
          <span class="v3-stat-label">Projects Completed</span>
        </div>
        <div class="v3-stat">
          <span class="v3-stat-num">100%</span>
          <span class="v3-stat-label">Client Satisfaction</span>
        </div>
        <div class="v3-stat">
          <span class="v3-stat-num">60+</span>
          <span class="v3-stat-label">Team Members</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== MISSION / VISION ===================== -->
  <section class="v3-section v3-bg-cream v3-texture">
    <div class="v3-container">
      <div class="v3-mv-grid">
        <div class="v3-mv-card v3-reveal">
          <div class="v3-mv-label">
            <span class="v3-label" style="color: var(--v3-ember);">Our Mission</span>
          </div>
          <h3 class="v3-display v3-display-md" style="margin-top: 1rem;">
            To deliver exceptional construction experiences through honest partnerships and uncompromising quality.
          </h3>
          <p class="v3-text" style="margin-top: 1rem; font-size: 1rem;">
            We believe every client deserves a builder who listens, communicates openly, and treats their project as if it were their own home. That is the You First promise.
          </p>
        </div>

        <div class="v3-mv-card v3-reveal v3-reveal-d2">
          <div class="v3-mv-label">
            <span class="v3-label" style="color: var(--v3-ember);">Our Vision</span>
          </div>
          <h3 class="v3-display v3-display-md" style="margin-top: 1rem;">
            To be the most trusted name in construction — one relationship at a time.
          </h3>
          <p class="v3-text" style="margin-top: 1rem; font-size: 1rem;">
            We are not chasing volume. We are building a legacy of quality, trust, and community impact that will endure for generations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== VALUES ===================== -->
  <section class="v3-section">
    <div class="v3-container">
      <div style="text-align: center;" class="v3-reveal">
        <div class="v3-badge">Our Values</div>
        <h2 class="v3-display v3-display-lg" style="margin-top: 1rem;">What guides every decision.</h2>
      </div>

      <div class="v3-values-grid">
        {values.map((v, i) => (
          <div class={`v3-val-card-about v3-reveal v3-reveal-d${(i % 6) + 1}`}>
            <div class="v3-val-header">
              <div class="v3-val-icon-wrap" set:html={v.icon} />
              <span class="v3-val-num">{v.num}</span>
            </div>
            <h4 class="v3-val-title">{v.title}</h4>
            <p class="v3-val-desc">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== TIMELINE ===================== -->
  <section class="v3-section v3-bg-dark v3-texture">
    <div class="v3-container">
      <div style="text-align: center;" class="v3-reveal">
        <div class="v3-badge v3-badge-light">Our Journey</div>
        <h2 class="v3-display v3-display-lg" style="margin-top: 1rem;">Milestones along the way.</h2>
      </div>

      <div class="v3-timeline">
        {milestones.map((m, i) => (
          <div class={`v3-timeline-item v3-reveal v3-reveal-d${(i % 6) + 1}`}>
            <div class="v3-timeline-marker">
              <div class="v3-timeline-dot"></div>
            </div>
            <div class="v3-timeline-content">
              <span class="v3-timeline-year">{m.year}</span>
              <p class="v3-timeline-event">{m.event}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== QUOTE ===================== -->
  <section class="v3-section v3-bg-cream v3-texture">
    <div class="v3-container">
      <div class="v3-quote-block v3-reveal">
        <div class="v3-quote-accent"></div>
        <blockquote class="v3-blockquote">
          <p class="v3-display v3-display-md" style="font-style: italic;">
            "Building a home is one of the biggest decisions a family makes. We treat that responsibility with the seriousness and care it deserves."
          </p>
          <footer class="v3-blockquote-footer">
            <div class="v3-ember-bar" style="width: 24px; height: 3px;"></div>
            <strong>Robert Martinez, Founder</strong>
            <span>You First Construction Inc.</span>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ===================== CTA BAND ===================== -->
  <section class="v3-cta-band">
    <div class="v3-container v3-reveal">
      <div class="v3-cta-content">
        <h2 class="v3-display v3-display-lg" style="color: white;">
          Ready to work with a team that puts you first?
        </h2>
        <p class="v3-cta-desc">
          Whether you are planning a new build, a remodel, or need restoration services, we are here to help make your vision a reality.
        </p>
      </div>
      <div class="v3-cta-actions">
        <a href="/v3/contact" class="v3-btn v3-btn-white">Get a Free Consultation</a>
        <a href="tel:5550123456" class="v3-cta-phone">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          (555) 012-3456
        </a>
      </div>
    </div>
  </section>
</V3Layout>

<style>
  /* ===================== HERO ===================== */
  .v3-about-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 860px) {
    .v3-about-hero-grid { grid-template-columns: 1.1fr 1fr; gap: 4rem; }
  }

  .v3-about-hero-img-inner {
    border-radius: var(--v3-radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ===================== STATS ===================== */
  .v3-about-stats {
    padding: 0 1.5rem 3rem;
  }

  .v3-about-stats .v3-stats-band {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--v3-radius-lg);
  }

  @media (min-width: 768px) {
    .v3-about-stats { padding: 0 2rem 4rem; }
  }

  /* ===================== MISSION / VISION ===================== */
  .v3-mv-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .v3-mv-grid { grid-template-columns: 1fr 1fr; }
  }

  .v3-mv-card {
    background: white;
    border: 1px solid rgba(42, 42, 42, 0.1);
    border-radius: var(--v3-radius-lg);
    padding: 2.5rem 2rem;
    position: relative;
  }

  .v3-mv-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--v3-ember);
    border-radius: var(--v3-radius-lg) var(--v3-radius-lg) 0 0;
  }

  /* ===================== VALUES ===================== */
  .v3-values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 3rem;
  }

  @media (min-width: 640px) {
    .v3-values-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 960px) {
    .v3-values-grid { grid-template-columns: 1fr 1fr 1fr; }
  }

  .v3-val-card-about {
    background: white;
    border: 1px solid rgba(42, 42, 42, 0.1);
    border-radius: var(--v3-radius-lg);
    padding: 2rem 1.75rem;
    transition: all 0.4s var(--v3-ease);
  }

  .v3-val-card-about:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px -8px rgba(42, 42, 42, 0.12);
    border-color: rgba(232, 97, 26, 0.2);
  }

  .v3-val-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .v3-val-icon-wrap {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--v3-cream);
    border-radius: var(--v3-radius);
    color: var(--v3-ember);
  }

  .v3-val-num {
    font-family: var(--v3-font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--v3-sand);
    line-height: 1;
  }

  .v3-val-title {
    font-family: var(--v3-font-body);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--v3-charcoal);
    margin-bottom: 0.5rem;
  }

  .v3-val-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--v3-charcoal-light);
  }

  /* ===================== TIMELINE ===================== */
  .v3-timeline {
    max-width: 640px;
    margin: 3rem auto 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }

  .v3-timeline::before {
    content: '';
    position: absolute;
    left: 9px;
    top: 28px;
    bottom: 28px;
    width: 2px;
    background: linear-gradient(to bottom, rgba(232, 97, 26, 0.4), rgba(232, 97, 26, 0.1));
    border-radius: 2px;
  }

  .v3-timeline-item {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem 0;
    position: relative;
  }

  .v3-timeline-marker {
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .v3-timeline-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--v3-charcoal);
    border: 3px solid var(--v3-ember);
    margin-top: 2px;
  }

  .v3-timeline-year {
    font-family: var(--v3-font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--v3-ember);
    display: block;
    margin-bottom: 0.25rem;
  }

  .v3-timeline-event {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
  }

  /* ===================== QUOTE ===================== */
  .v3-quote-block {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
  }

  .v3-quote-accent {
    position: absolute;
    top: -1rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--v3-font-display);
    font-size: 6rem;
    font-weight: 800;
    color: var(--v3-ember);
    opacity: 0.15;
    line-height: 1;
    pointer-events: none;
  }

  .v3-quote-accent::before {
    content: '\201C';
  }

  .v3-blockquote {
    text-align: center;
    padding: 3rem 2rem;
    background: white;
    border-radius: var(--v3-radius-lg);
    border: 1px solid rgba(42, 42, 42, 0.1);
    border-left: 4px solid var(--v3-ember);
  }

  .v3-blockquote-footer {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--v3-font-body);
    font-size: 0.9375rem;
    color: var(--v3-charcoal-light);
  }

  .v3-blockquote-footer span {
    font-size: 0.8125rem;
    color: var(--v3-stone);
  }
</style>
