---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentPage?: string;
}

const {
  title = 'You First Construction | Custom Home Builders',
  description = 'Premium custom home construction, remodeling, and restoration services.',
  currentPage = 'home',
} = Astro.props;

const navLinks = [
  { href: '/v3', label: 'Home', page: 'home' },
  { href: '/v3/services', label: 'Services', page: 'services' },
  { href: '/v3/projects', label: 'Projects', page: 'projects' },
  { href: '/v3/about', label: 'About', page: 'about' },
  { href: '/v3/contact', label: 'Contact', page: 'contact' },
];

const currentYear = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body class="v3-body">
    <!-- Fixed Nav -->
    <header class="v3-header" id="v3-header">
      <div class="v3-nav-bar">
        <a href="/v3" class="v3-logo-link">
          <img src="/logo.png" alt="You First Construction" class="v3-logo-img" />
        </a>

        <nav class="v3-nav-desktop" aria-label="Main navigation">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={['v3-nav-link', { 'is-active': currentPage === link.page }]}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <div class="v3-nav-actions">
          <a href="/" class="v3-nav-versions">All Versions</a>
          <a href="/v3/contact" class="v3-nav-cta">Get a Quote</a>
        </div>

        <button
          class="v3-burger"
          id="v3-burger"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </button>
      </div>
    </header>

    <!-- Mobile overlay -->
    <div class="v3-mobile-overlay" id="v3-mobile-overlay">
      <nav class="v3-mobile-nav" aria-label="Mobile navigation">
        {navLinks.map((link, i) => (
          <a
            href={link.href}
            class:list={['v3-mobile-link', { 'is-active': currentPage === link.page }]}
            style={`transition-delay: ${0.05 + i * 0.06}s`}
          >
            <span class="v3-mobile-link-num">0{i + 1}</span>
            {link.label}
          </a>
        ))}
        <div class="v3-mobile-actions">
          <a href="/v3/contact" class="v3-mobile-cta">Get a Quote</a>
          <a href="/" class="v3-mobile-versions">All Versions</a>
        </div>
      </nav>
    </div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="v3-footer">
      <div class="v3-footer-inner">
        <div class="v3-footer-top">
          <div class="v3-footer-brand">
            <img src="/logo.png" alt="You First Construction" class="v3-footer-logo" />
            <p class="v3-footer-tagline">
              Building dreams with integrity since 2000. From blueprints to move-in, we put you first.
            </p>
          </div>

          <div class="v3-footer-cols">
            <div class="v3-footer-col">
              <h4 class="v3-footer-heading">Services</h4>
              <a href="/v3/services" class="v3-footer-link">New Construction</a>
              <a href="/v3/services" class="v3-footer-link">Remodeling</a>
              <a href="/v3/services" class="v3-footer-link">Commercial</a>
              <a href="/v3/services" class="v3-footer-link">Restoration</a>
            </div>

            <div class="v3-footer-col">
              <h4 class="v3-footer-heading">Company</h4>
              <a href="/v3/about" class="v3-footer-link">Our Story</a>
              <a href="/v3/projects" class="v3-footer-link">Projects</a>
              <a href="/v3/contact" class="v3-footer-link">Contact</a>
            </div>

            <div class="v3-footer-col">
              <h4 class="v3-footer-heading">Get in Touch</h4>
              <p class="v3-footer-info">(555) 012-3456</p>
              <p class="v3-footer-info">info@youfirstconstruction.com</p>
              <p class="v3-footer-info">Houston, TX</p>
            </div>
          </div>
        </div>

        <div class="v3-footer-bottom">
          <p>&copy; {currentYear} You First Construction Inc. All rights reserved.</p>
          <div class="v3-footer-bottom-links">
            <a href="/">All Versions</a>
            <a href="/v1">V1</a>
            <a href="/v2">V2</a>
            <a href="/v3">V3</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Scripts -->
    <script>
      const burger = document.getElementById('v3-burger');
      const overlay = document.getElementById('v3-mobile-overlay');
      const header = document.getElementById('v3-header');

      burger?.addEventListener('click', () => {
        const isOpen = overlay?.classList.toggle('is-open');
        burger.classList.toggle('is-open');
        burger.setAttribute('aria-expanded', String(isOpen));
        document.body.style.overflow = isOpen ? 'hidden' : '';
      });

      overlay?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          overlay.classList.remove('is-open');
          burger?.classList.remove('is-open');
          burger?.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        });
      });

      window.addEventListener('scroll', () => {
        if (window.scrollY > 40) {
          header?.classList.add('is-scrolled');
        } else {
          header?.classList.remove('is-scrolled');
        }
      }, { passive: true });

      // Scroll reveal
      const v3Observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.v3-reveal').forEach((el) => v3Observer.observe(el));
    </script>

    <style is:global>
      /* ============================================
         V3 — "Warm Industrial" Design System
         Playfair Display + Manrope
         Concrete textures, amber warmth, real weight
         ============================================ */

      :root {
        --v3-white: #FAF9F7;
        --v3-cream: #F3EDE4;
        --v3-sand: #D9D2C7;
        --v3-stone: #B8AFA3;
        --v3-charcoal: #2A2A2A;
        --v3-charcoal-mid: #3D3D3D;
        --v3-charcoal-light: #5A5A5A;
        --v3-ember: #E8611A;
        --v3-ember-dark: #C44D0F;
        --v3-ember-light: #F4845F;
        --v3-ember-glow: rgba(232, 97, 26, 0.15);
        --v3-radius: 6px;
        --v3-radius-lg: 12px;
        --v3-font-display: 'Playfair Display', Georgia, serif;
        --v3-font-body: 'Manrope', system-ui, sans-serif;
        --v3-ease: cubic-bezier(0.16, 1, 0.3, 1);
      }

      .v3-body {
        font-family: var(--v3-font-body);
        color: var(--v3-charcoal);
        background: var(--v3-white);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      .v3-body ::selection {
        background: var(--v3-ember);
        color: white;
      }

      /* ---------- Concrete texture (SVG noise) ---------- */
      .v3-texture::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        opacity: 0.035;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 200px 200px;
      }

      /* ---------- Header ---------- */
      .v3-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        padding: 1rem 1.5rem;
        transition: all 0.4s var(--v3-ease);
      }

      .v3-header.is-scrolled {
        padding: 0.5rem 1.5rem;
      }

      .v3-nav-bar {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(250, 249, 247, 0.92);
        backdrop-filter: blur(24px) saturate(1.8);
        -webkit-backdrop-filter: blur(24px) saturate(1.8);
        border: 1px solid rgba(61, 61, 61, 0.08);
        border-radius: var(--v3-radius-lg);
        padding: 0.625rem 0.75rem 0.625rem 1.25rem;
        box-shadow: 0 2px 8px rgba(42, 42, 42, 0.06), 0 12px 48px rgba(42, 42, 42, 0.04);
        transition: all 0.4s var(--v3-ease);
      }

      .v3-header.is-scrolled .v3-nav-bar {
        box-shadow: 0 4px 12px rgba(42, 42, 42, 0.08), 0 20px 60px rgba(42, 42, 42, 0.08);
        background: rgba(250, 249, 247, 0.96);
      }

      .v3-logo-link {
        display: flex;
        align-items: center;
        flex-shrink: 0;
      }

      .v3-logo-img {
        height: 30px;
        width: auto;
      }

      .v3-nav-desktop {
        display: none;
        align-items: center;
        gap: 0.125rem;
        margin-left: auto;
        margin-right: 0.5rem;
      }

      .v3-nav-actions {
        display: none;
        align-items: center;
        gap: 0.75rem;
      }

      @media (min-width: 860px) {
        .v3-nav-desktop { display: flex; }
        .v3-nav-actions { display: flex; }
        .v3-burger { display: none !important; }
      }

      .v3-nav-link {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--v3-charcoal-light);
        text-decoration: none;
        padding: 0.5rem 0.875rem;
        border-radius: var(--v3-radius);
        transition: color 0.2s, background 0.2s;
        letter-spacing: 0.01em;
      }

      .v3-nav-link:hover {
        color: var(--v3-charcoal);
        background: rgba(42, 42, 42, 0.06);
      }

      .v3-nav-link.is-active {
        color: var(--v3-ember);
        background: rgba(232, 97, 26, 0.1);
        font-weight: 700;
      }

      .v3-nav-versions {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8125rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--v3-charcoal);
        text-decoration: none;
        padding: 0.625rem 1rem;
        border-radius: var(--v3-radius);
        border: 1px solid rgba(42, 42, 42, 0.12);
        background: rgba(255, 255, 255, 0.7);
        transition: border-color 0.25s, background 0.25s, color 0.25s, transform 0.3s var(--v3-ease);
      }

      .v3-nav-versions:hover {
        color: var(--v3-ember-dark);
        border-color: rgba(232, 97, 26, 0.28);
        background: rgba(232, 97, 26, 0.08);
        transform: translateY(-1px);
      }

      .v3-nav-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        color: white;
        background: var(--v3-ember);
        text-decoration: none;
        padding: 0.625rem 1.5rem;
        border-radius: var(--v3-radius);
        transition: background 0.3s, transform 0.3s var(--v3-ease), box-shadow 0.3s;
        box-shadow: 0 2px 8px rgba(232, 97, 26, 0.3);
      }

      .v3-nav-cta:hover {
        background: var(--v3-ember-dark);
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(232, 97, 26, 0.4);
      }

      /* ---------- Burger ---------- */
      .v3-burger {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 4px;
        width: 42px;
        height: 42px;
        background: none;
        border: none;
        cursor: pointer;
        margin-left: auto;
        padding: 0;
        border-radius: var(--v3-radius);
      }

      .v3-burger span {
        display: block;
        width: 22px;
        height: 2.5px;
        background: var(--v3-charcoal);
        border-radius: 2px;
        transition: transform 0.35s var(--v3-ease), opacity 0.2s;
        transform-origin: center;
      }

      .v3-burger.is-open span:first-child { transform: translateY(6.5px) rotate(45deg); }
      .v3-burger.is-open span:nth-child(2) { opacity: 0; }
      .v3-burger.is-open span:last-child { transform: translateY(-6.5px) rotate(-45deg); }

      /* ---------- Mobile Overlay ---------- */
      .v3-mobile-overlay {
        position: fixed;
        inset: 0;
        z-index: 999;
        background: var(--v3-charcoal);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s var(--v3-ease);
      }

      .v3-mobile-overlay.is-open {
        opacity: 1;
        pointer-events: auto;
      }

      .v3-mobile-nav {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.25rem;
        padding: 0 2rem;
      }

      .v3-mobile-actions {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.875rem;
        margin-top: 2rem;
      }

      .v3-mobile-link {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        font-family: var(--v3-font-display);
        font-size: 2.5rem;
        font-weight: 600;
        color: white;
        text-decoration: none;
        padding: 0.5rem 0;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.5s var(--v3-ease), transform 0.5s var(--v3-ease), color 0.2s;
      }

      .v3-mobile-overlay.is-open .v3-mobile-link {
        opacity: 1;
        transform: translateY(0);
      }

      .v3-mobile-link:hover { color: var(--v3-ember-light); }
      .v3-mobile-link.is-active { color: var(--v3-ember); }

      .v3-mobile-link-num {
        font-family: var(--v3-font-body);
        font-size: 0.75rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.3);
        letter-spacing: 0.05em;
      }

      .v3-mobile-cta {
        font-family: var(--v3-font-body);
        font-size: 1rem;
        font-weight: 700;
        color: white;
        background: var(--v3-ember);
        text-decoration: none;
        padding: 1rem 2.5rem;
        border-radius: var(--v3-radius);
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.5s var(--v3-ease) 0.35s, transform 0.5s var(--v3-ease) 0.35s, background 0.2s;
      }

      .v3-mobile-overlay.is-open .v3-mobile-cta {
        opacity: 1;
        transform: translateY(0);
      }

      .v3-mobile-cta:hover { background: var(--v3-ember-dark); }

      .v3-mobile-versions {
        font-family: var(--v3-font-body);
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        padding: 0.875rem 1.25rem;
        border-radius: var(--v3-radius);
        border: 1px solid rgba(255, 255, 255, 0.16);
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.5s var(--v3-ease) 0.42s,
          transform 0.5s var(--v3-ease) 0.42s,
          color 0.2s,
          border-color 0.2s,
          background 0.2s;
      }

      .v3-mobile-overlay.is-open .v3-mobile-versions {
        opacity: 1;
        transform: translateY(0);
      }

      .v3-mobile-versions:hover {
        color: white;
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.28);
      }

      /* ---------- Footer ---------- */
      .v3-footer {
        background: var(--v3-charcoal);
        color: rgba(255, 255, 255, 0.65);
        padding: 5rem 1.5rem 2.5rem;
        position: relative;
        overflow: hidden;
      }

      .v3-footer::before {
        content: '';
        position: absolute;
        inset: 0;
        opacity: 0.03;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 200px;
        pointer-events: none;
      }

      .v3-footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
      }

      .v3-footer-top {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
      }

      @media (min-width: 860px) {
        .v3-footer-top {
          grid-template-columns: 1.4fr 2fr;
          gap: 4rem;
        }
      }

      .v3-footer-brand { max-width: 340px; }

      .v3-footer-logo {
        height: 36px;
        width: auto;
        filter: brightness(0) invert(1);
        margin-bottom: 1.25rem;
      }

      .v3-footer-tagline {
        font-size: 0.9375rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.45);
      }

      .v3-footer-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
      }

      @media (min-width: 640px) {
        .v3-footer-cols {
          grid-template-columns: 1fr 1fr 1.2fr;
        }
      }

      .v3-footer-col {
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
      }

      .v3-footer-heading {
        font-size: 0.8125rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--v3-ember);
        margin-bottom: 0.5rem;
      }

      .v3-footer-link {
        font-size: 0.9375rem;
        color: rgba(255, 255, 255, 0.55);
        text-decoration: none;
        transition: color 0.2s;
      }

      .v3-footer-link:hover { color: white; }

      .v3-footer-info {
        font-size: 0.9375rem;
        color: rgba(255, 255, 255, 0.45);
        line-height: 1.7;
      }

      .v3-footer-bottom {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: center;
        text-align: center;
        font-size: 0.8125rem;
        color: rgba(255, 255, 255, 0.25);
      }

      @media (min-width: 640px) {
        .v3-footer-bottom {
          flex-direction: row;
          justify-content: space-between;
          text-align: left;
        }
      }

      .v3-footer-bottom-links {
        display: flex;
        gap: 1.25rem;
      }

      .v3-footer-bottom-links a {
        color: rgba(255, 255, 255, 0.25);
        text-decoration: none;
        transition: color 0.2s;
      }

      .v3-footer-bottom-links a:hover { color: var(--v3-ember-light); }

      /* ============================================
         V3 — Shared Utilities
         ============================================ */

      .v3-section {
        padding: 5rem 1.5rem;
        position: relative;
      }

      @media (min-width: 768px) {
        .v3-section { padding: 7rem 2rem; }
      }

      .v3-container {
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
      }

      /* Badge */
      .v3-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--v3-ember);
        background: rgba(232, 97, 26, 0.12);
        padding: 0.5rem 1rem;
        border-radius: var(--v3-radius);
        border-left: 3px solid var(--v3-ember);
      }

      .v3-badge-light {
        color: var(--v3-ember-light);
        background: rgba(232, 97, 26, 0.15);
        border-left-color: var(--v3-ember-light);
      }

      /* Display headings */
      .v3-display {
        font-family: var(--v3-font-display);
        font-weight: 700;
        line-height: 1.08;
        color: var(--v3-charcoal);
        letter-spacing: -0.015em;
      }

      .v3-display-xl { font-size: clamp(2.75rem, 6vw, 5rem); }
      .v3-display-lg { font-size: clamp(2.25rem, 4.5vw, 3.75rem); }
      .v3-display-md { font-size: clamp(1.5rem, 3vw, 2.5rem); }
      .v3-display-sm { font-size: clamp(1.25rem, 2vw, 1.625rem); }

      /* Text */
      .v3-text {
        font-size: 1.125rem;
        line-height: 1.75;
        color: var(--v3-charcoal-light);
      }

      .v3-text-lg {
        font-size: 1.25rem;
        line-height: 1.7;
      }

      /* Label */
      .v3-label {
        font-size: 0.8125rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--v3-stone);
      }

      /* Card */
      .v3-card {
        background: white;
        border: 1px solid rgba(42, 42, 42, 0.1);
        border-radius: var(--v3-radius-lg);
        padding: 2rem;
        transition: transform 0.4s var(--v3-ease), box-shadow 0.4s, border-color 0.3s;
      }

      .v3-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 48px -8px rgba(42, 42, 42, 0.12);
        border-color: rgba(232, 97, 26, 0.2);
      }

      /* Dark card */
      .v3-card-dark {
        background: var(--v3-charcoal);
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: white;
      }

      .v3-card-dark:hover {
        border-color: rgba(232, 97, 26, 0.3);
        box-shadow: 0 16px 48px -8px rgba(0, 0, 0, 0.3);
      }

      /* Buttons */
      .v3-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-family: var(--v3-font-body);
        font-size: 0.9375rem;
        font-weight: 700;
        text-decoration: none;
        padding: 0.875rem 2rem;
        border-radius: var(--v3-radius);
        transition: all 0.3s var(--v3-ease);
        cursor: pointer;
        border: none;
        letter-spacing: 0.01em;
      }

      .v3-btn-primary {
        color: white;
        background: var(--v3-ember);
        box-shadow: 0 4px 16px rgba(232, 97, 26, 0.3);
      }

      .v3-btn-primary:hover {
        background: var(--v3-ember-dark);
        box-shadow: 0 8px 32px rgba(232, 97, 26, 0.4);
        transform: translateY(-2px);
      }

      .v3-btn-dark {
        color: white;
        background: var(--v3-charcoal);
        box-shadow: 0 4px 16px rgba(42, 42, 42, 0.2);
      }

      .v3-btn-dark:hover {
        background: #1a1a1a;
        box-shadow: 0 8px 32px rgba(42, 42, 42, 0.3);
        transform: translateY(-2px);
      }

      .v3-btn-outline {
        color: var(--v3-charcoal);
        background: transparent;
        border: 2px solid var(--v3-charcoal);
      }

      .v3-btn-outline:hover {
        color: white;
        background: var(--v3-charcoal);
        transform: translateY(-2px);
      }

      .v3-btn-white {
        color: var(--v3-charcoal);
        background: white;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
      }

      .v3-btn-white:hover {
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.15);
        transform: translateY(-2px);
      }

      /* Backgrounds */
      .v3-bg-dark {
        background: var(--v3-charcoal);
        color: white;
        position: relative;
        overflow: hidden;
      }

      .v3-bg-dark .v3-display { color: white; }
      .v3-bg-dark .v3-text { color: rgba(255, 255, 255, 0.7); }
      .v3-bg-dark .v3-label { color: rgba(255, 255, 255, 0.4); }
      .v3-bg-dark .v3-badge {
        color: var(--v3-ember-light);
        background: rgba(232, 97, 26, 0.15);
        border-left-color: var(--v3-ember-light);
      }

      .v3-bg-cream {
        background: var(--v3-cream);
        position: relative;
        overflow: hidden;
      }

      /* Image placeholder with construction texture */
      .v3-img-placeholder {
        width: 100%;
        height: 100%;
        background:
          repeating-linear-gradient(
            45deg,
            transparent,
            transparent 20px,
            rgba(42, 42, 42, 0.03) 20px,
            rgba(42, 42, 42, 0.03) 21px
          ),
          linear-gradient(135deg, var(--v3-sand) 0%, var(--v3-stone) 100%);
        position: relative;
      }

      .v3-img-placeholder::after {
        content: '';
        position: absolute;
        inset: 0;
        opacity: 0.06;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 200px;
      }

      /* Ember accent line */
      .v3-ember-bar {
        width: 48px;
        height: 4px;
        background: var(--v3-ember);
        border-radius: 2px;
      }

      /* Scroll reveal */
      .v3-reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.7s var(--v3-ease), transform 0.7s var(--v3-ease);
      }

      .v3-reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      .v3-reveal-d1 { transition-delay: 0.08s; }
      .v3-reveal-d2 { transition-delay: 0.16s; }
      .v3-reveal-d3 { transition-delay: 0.24s; }
      .v3-reveal-d4 { transition-delay: 0.32s; }
      .v3-reveal-d5 { transition-delay: 0.4s; }
      .v3-reveal-d6 { transition-delay: 0.48s; }
      .v3-reveal-d7 { transition-delay: 0.56s; }
      .v3-reveal-d8 { transition-delay: 0.64s; }

      /* ============================================
         Shared: Inner Page Hero (dark)
         ============================================ */
      .v3-page-hero {
        padding: 9rem 1.5rem 4.5rem;
        position: relative;
        overflow: hidden;
      }

      .v3-page-hero::after {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 40%;
        height: 100%;
        background: radial-gradient(ellipse at 80% 40%, rgba(232, 97, 26, 0.08) 0%, transparent 60%);
        pointer-events: none;
      }

      @media (min-width: 768px) {
        .v3-page-hero { padding: 11rem 2rem 5.5rem; }
      }

      /* ============================================
         Shared: Breadcrumbs
         ============================================ */
      .v3-breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8125rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
      }

      .v3-breadcrumb a {
        color: rgba(255, 255, 255, 0.4);
        text-decoration: none;
        transition: color 0.2s;
      }

      .v3-breadcrumb a:hover {
        color: rgba(255, 255, 255, 0.7);
      }

      .v3-breadcrumb-sep {
        color: rgba(255, 255, 255, 0.2);
      }

      .v3-breadcrumb-current {
        color: var(--v3-ember-light);
      }

      /* ============================================
         Shared: CTA Band (ember)
         ============================================ */
      .v3-cta-band {
        background: var(--v3-ember);
        padding: 4rem 1.5rem;
        position: relative;
        overflow: hidden;
      }

      .v3-cta-band::before {
        content: '';
        position: absolute;
        inset: 0;
        opacity: 0.06;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 200px;
        pointer-events: none;
      }

      .v3-cta-band .v3-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        align-items: center;
      }

      @media (min-width: 768px) {
        .v3-cta-band { padding: 5rem 2rem; }
        .v3-cta-band .v3-container { grid-template-columns: 1.5fr 1fr; }
      }

      .v3-cta-content { /* structural wrapper for CTA text */ }

      .v3-cta-desc {
        font-size: 1.0625rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.85);
        margin-top: 0.75rem;
        max-width: 480px;
      }

      .v3-cta-actions {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: flex-start;
      }

      @media (min-width: 768px) {
        .v3-cta-actions { align-items: flex-end; }
      }

      .v3-cta-phone {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.125rem;
        font-weight: 700;
        color: white;
        text-decoration: none;
        transition: opacity 0.2s;
      }

      .v3-cta-phone:hover { opacity: 0.8; }

      /* ============================================
         Shared: Stats Band
         ============================================ */
      .v3-stats-band {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
      }

      @media (min-width: 640px) {
        .v3-stats-band { grid-template-columns: 1fr 1fr 1fr 1fr; }
      }

      .v3-stats-band .v3-stat {
        padding: 2.5rem 1.5rem;
        text-align: center;
        border-right: 1px solid rgba(255, 255, 255, 0.06);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      .v3-stats-band .v3-stat:last-child { border-right: none; }

      @media (min-width: 640px) {
        .v3-stats-band .v3-stat { border-bottom: none; }
      }

      .v3-stat-num {
        display: block;
        font-family: var(--v3-font-display);
        font-size: 2.75rem;
        font-weight: 800;
        color: var(--v3-ember);
        line-height: 1;
        letter-spacing: -0.02em;
      }

      .v3-stat-label {
        display: block;
        font-size: 0.8125rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.45);
        margin-top: 0.5rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
    </style>
  </body>
</html>
