---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentPage?: string;
}

const {
  title = 'You First Construction | Custom Home Builders',
  description = 'Premium custom home construction, remodeling, and restoration services.',
  currentPage = 'home',
} = Astro.props;

const navLinks = [
  { href: '/v2', label: 'Home', page: 'home' },
  { href: '/v2/services', label: 'Services', page: 'services' },
  { href: '/v2/about', label: 'About', page: 'about' },
  { href: '/v2/projects', label: 'Projects', page: 'projects' },
  { href: '/v2/contact', label: 'Contact', page: 'contact' },
];

const currentYear = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700&family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>

  <body class="v2-body">
    <!-- ========== NAV ========== -->
    <nav class="v2-nav">
      <div class="v2-nav__inner">
        <!-- Logo -->
        <a href="/v2" class="v2-nav__logo">
          <img src="/logo.png" alt="You First Construction" />
        </a>

        <!-- Desktop links -->
        <div class="v2-nav__links">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={['v2-nav__link', { 'is-active': currentPage === link.page }]}
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- CTA + Versions -->
        <div class="v2-nav__actions">
          <a href="/" class="v2-nav__versions">All Versions</a>
          <a href="/v2/contact" class="v2-nav__cta">Get a Quote</a>
        </div>

        <!-- Mobile toggle -->
        <button id="v2-mob-toggle" class="v2-nav__burger" aria-label="Menu">
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>

    <!-- Mobile overlay -->
    <div id="v2-mob-overlay" class="v2-mob">
      <div class="v2-mob__inner">
        {navLinks.map((link, i) => (
          <a
            href={link.href}
            class:list={['v2-mob__link', { 'is-active': currentPage === link.page }]}
            style={`--i:${i}`}
          >
            <span class="v2-mob__num">0{i + 1}</span>
            {link.label}
          </a>
        ))}
        <div class="v2-mob__footer">
          <a href="/v2/contact" class="v2-nav__cta">Get a Quote</a>
          <a href="/" class="v2-mob__versions">All Versions</a>
        </div>
      </div>
    </div>

    <!-- ========== PAGE CONTENT ========== -->
    <main class="v2-main">
      <slot />
    </main>

    <!-- ========== FOOTER ========== -->
    <footer class="v2-footer">
      <div class="v2-footer__top">
        <div class="v2-footer__brand">
          <a href="/v2">
            <img src="/logo.png" alt="You First Construction" class="v2-footer__logo" />
          </a>
          <p>Premium custom home construction, remodeling, and restoration. Putting you first since 1999.</p>
        </div>
        <div class="v2-footer__cols">
          <div>
            <h4>New Construction</h4>
            <ul>
              <li><a href="/v2/services">Commercial & Residential</a></li>
              <li><a href="/v2/services">Custom & Spec Homes</a></li>
              <li><a href="/v2/services">Shell Construction</a></li>
            </ul>
          </div>
          <div>
            <h4>Remodeling</h4>
            <ul>
              <li><a href="/v2/services">Commercial & Residential</a></li>
              <li><a href="/v2/services">High-End Remodels</a></li>
              <li><a href="/v2/services">Restoration & Recovery</a></li>
            </ul>
          </div>
          <div>
            <h4>Company</h4>
            <ul>
              <li><a href="/v2/about">About Us</a></li>
              <li><a href="/v2/projects">Projects</a></li>
              <li><a href="/v2/contact">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4>Reach Us</h4>
            <ul>
              <li><a href="tel:+15551234567">(555) 123-4567</a></li>
              <li><a href="mailto:info@youfirstconstruction.com">info@youfirst.com</a></li>
              <li>Los Angeles, CA</li>
              <li>Mon–Fri 8am–6pm</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="v2-footer__bottom">
        <span>&copy; {currentYear} You First Construction Inc.</span>
        <span>
          <a href="#">Privacy</a>
          <a href="#">Terms</a>
        </span>
      </div>
    </footer>

    <!-- Mobile menu script -->
    <script>
      const toggle = document.getElementById('v2-mob-toggle');
      const overlay = document.getElementById('v2-mob-overlay');
      let open = false;
      toggle?.addEventListener('click', () => {
        open = !open;
        overlay?.classList.toggle('is-open', open);
        toggle?.classList.toggle('is-open', open);
        document.body.style.overflow = open ? 'hidden' : '';
      });
      overlay?.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          open = false;
          overlay?.classList.remove('is-open');
          toggle?.classList.remove('is-open');
          document.body.style.overflow = '';
        });
      });
    </script>

    <style is:global>
      /* =============================================
         V2 DESIGN SYSTEM — Warm Brutalist Editorial
         Completely different from V1
         ============================================= */

      .v2-body {
        font-family: var(--font-body);
        color: var(--color-charcoal);
        background: var(--color-limestone);
        overflow-x: hidden;
      }

      /* ---------- NAV ---------- */
      .v2-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: var(--color-limestone);
        border-bottom: 3px solid var(--color-charcoal-dark);
      }
      .v2-nav__inner {
        max-width: 1440px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 72px;
      }
      .v2-nav__logo img {
        height: 40px;
        width: auto;
      }
      .v2-nav__links {
        display: none;
        gap: 0;
      }
      @media (min-width: 1024px) {
        .v2-nav__links { display: flex; }
      }
      .v2-nav__link {
        font-family: var(--font-heading);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-charcoal-light);
        padding: 0.6rem 1.25rem;
        border: 2px solid transparent;
        transition: all 0.25s ease;
        text-decoration: none;
      }
      .v2-nav__link:hover {
        color: var(--color-ember);
        border-bottom-color: var(--color-ember);
      }
      .v2-nav__link.is-active {
        color: var(--color-charcoal-dark);
        border: 2px solid var(--color-charcoal-dark);
        background: var(--color-bone);
      }
      .v2-nav__actions {
        display: none;
        align-items: center;
        gap: 1rem;
      }
      @media (min-width: 1024px) {
        .v2-nav__actions { display: flex; }
      }
      .v2-nav__versions {
        font-family: var(--font-heading);
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--color-slate);
        text-decoration: none;
        transition: color 0.25s ease;
      }
      .v2-nav__versions:hover { color: var(--color-ember); }
      .v2-nav__cta {
        display: inline-block;
        font-family: var(--font-heading);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: white;
        background: var(--color-ember);
        padding: 0.7rem 1.5rem;
        text-decoration: none;
        transition: background 0.25s ease;
      }
      .v2-nav__cta:hover { background: var(--color-ember-dark); }

      /* Burger */
      .v2-nav__burger {
        display: flex;
        flex-direction: column;
        gap: 6px;
        width: 32px;
        height: 32px;
        justify-content: center;
        align-items: flex-end;
        cursor: pointer;
        background: none;
        border: none;
        padding: 0;
      }
      @media (min-width: 1024px) {
        .v2-nav__burger { display: none; }
      }
      .v2-nav__burger span {
        display: block;
        height: 3px;
        background: var(--color-charcoal-dark);
        transition: all 0.3s ease;
      }
      .v2-nav__burger span:first-child { width: 28px; }
      .v2-nav__burger span:last-child { width: 20px; }
      .v2-nav__burger.is-open span:first-child {
        transform: rotate(45deg) translate(3px, 3px);
        width: 28px;
      }
      .v2-nav__burger.is-open span:last-child {
        transform: rotate(-45deg) translate(3px, -3px);
        width: 28px;
      }

      /* ---------- MOBILE OVERLAY ---------- */
      .v2-mob {
        position: fixed;
        inset: 0;
        z-index: 90;
        background: var(--color-charcoal-dark);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s ease;
      }
      .v2-mob.is-open {
        opacity: 1;
        pointer-events: auto;
      }
      .v2-mob__inner { text-align: center; }
      .v2-mob__link {
        display: block;
        font-family: var(--font-display);
        font-size: 2.5rem;
        color: white;
        text-decoration: none;
        padding: 0.5rem 0;
        transition: color 0.3s ease;
      }
      .v2-mob__link:hover,
      .v2-mob__link.is-active { color: var(--color-ember); }
      .v2-mob__num {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        color: var(--color-ember);
        opacity: 0.5;
        vertical-align: super;
        margin-right: 0.5rem;
      }
      .v2-mob__footer {
        margin-top: 3rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }
      .v2-mob__versions {
        font-family: var(--font-heading);
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--color-steel);
        text-decoration: none;
      }

      /* ---------- MAIN ---------- */
      .v2-main {
        padding-top: 72px; /* nav height */
      }

      /* ---------- FOOTER ---------- */
      .v2-footer {
        background: var(--color-charcoal-dark);
        border-top: 4px solid var(--color-ember);
      }
      .v2-footer__top {
        max-width: 1440px;
        margin: 0 auto;
        padding: 4rem 2rem;
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
      }
      @media (min-width: 768px) {
        .v2-footer__top {
          grid-template-columns: 1.2fr 2fr;
          gap: 4rem;
        }
      }
      .v2-footer__brand p {
        font-size: 0.875rem;
        color: var(--color-steel);
        line-height: 1.7;
        margin-top: 1.25rem;
        max-width: 300px;
      }
      .v2-footer__logo {
        height: 48px;
        width: auto;
        filter: brightness(2) contrast(0.75);
      }
      .v2-footer__cols {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
      }
      @media (min-width: 768px) {
        .v2-footer__cols { grid-template-columns: repeat(4, 1fr); }
      }
      .v2-footer__cols h4 {
        font-family: var(--font-heading);
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--color-ember);
        margin-bottom: 1rem;
      }
      .v2-footer__cols ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .v2-footer__cols li {
        font-size: 0.85rem;
        color: var(--color-steel);
        margin-bottom: 0.5rem;
      }
      .v2-footer__cols a {
        color: var(--color-steel);
        text-decoration: none;
        transition: color 0.25s ease;
      }
      .v2-footer__cols a:hover { color: white; }
      .v2-footer__bottom {
        max-width: 1440px;
        margin: 0 auto;
        padding: 1.5rem 2rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        color: rgba(156,163,175,0.5);
        text-transform: uppercase;
      }
      .v2-footer__bottom a {
        color: rgba(156,163,175,0.5);
        text-decoration: none;
        margin-left: 1.5rem;
        transition: color 0.25s ease;
      }
      .v2-footer__bottom a:hover { color: var(--color-ember); }

      /* =============================================
         V2 REUSABLE PIECES
         ============================================= */

      /* Page header band — used at top of each interior page */
      .v2-page-header {
        background: var(--color-charcoal-dark);
        color: white;
        padding: 5rem 2rem 4rem;
      }
      .v2-page-header__inner {
        max-width: 1440px;
        margin: 0 auto;
      }
      .v2-page-header__crumb {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--color-ember);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }
      .v2-page-header__crumb span { color: var(--color-steel); }
      .v2-page-header h1 {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 6vw, 5rem);
        line-height: 0.95;
        letter-spacing: -0.02em;
        max-width: 700px;
      }
      .v2-page-header p {
        font-size: 1.125rem;
        color: var(--color-steel);
        line-height: 1.7;
        max-width: 540px;
        margin-top: 1.5rem;
      }

      /* Section wrapper */
      .v2-section {
        max-width: 1440px;
        margin: 0 auto;
        padding: 5rem 2rem;
      }
      @media (min-width: 1024px) {
        .v2-section { padding: 7rem 2rem; }
      }

      /* Thick accent bar */
      .v2-bar {
        width: 48px;
        height: 5px;
        background: var(--color-ember);
        display: block;
      }

      /* Box — the core v2 card style: thick border, no shadow, no radius */
      .v2-box {
        border: 3px solid var(--color-charcoal-dark);
        background: var(--color-bone);
        padding: 2rem;
        transition: all 0.35s ease;
      }
      .v2-box:hover {
        background: var(--color-charcoal-dark);
        color: white;
      }
      .v2-box:hover .v2-box__title { color: var(--color-ember); }
      .v2-box:hover .v2-box__desc { color: var(--color-steel); }
      .v2-box:hover .v2-box__tag { color: var(--color-ember); }

      .v2-box__tag {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--color-ember);
        margin-bottom: 1.25rem;
        display: block;
      }
      .v2-box__title {
        font-family: var(--font-display);
        font-size: 1.5rem;
        line-height: 1.15;
        color: var(--color-charcoal-dark);
        margin-bottom: 0.75rem;
        transition: color 0.35s ease;
      }
      .v2-box__desc {
        font-size: 0.95rem;
        color: var(--color-slate);
        line-height: 1.7;
        transition: color 0.35s ease;
      }

      /* Horizontal rule */
      .v2-hr {
        border: none;
        border-top: 3px solid var(--color-charcoal-dark);
        margin: 0;
      }
      .v2-hr--thin {
        border-top-width: 1px;
        border-color: var(--color-sand);
      }

      /* Button styles */
      .v2-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        font-family: var(--font-heading);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        text-decoration: none;
        padding: 1rem 2rem;
        border: 3px solid var(--color-charcoal-dark);
        color: var(--color-charcoal-dark);
        background: transparent;
        transition: all 0.3s ease;
        cursor: pointer;
      }
      .v2-btn:hover {
        background: var(--color-charcoal-dark);
        color: white;
      }
      .v2-btn--fill {
        background: var(--color-ember);
        border-color: var(--color-ember);
        color: white;
      }
      .v2-btn--fill:hover {
        background: var(--color-ember-dark);
        border-color: var(--color-ember-dark);
        color: white;
      }
      .v2-btn svg {
        width: 16px;
        height: 16px;
        transition: transform 0.3s ease;
      }
      .v2-btn:hover svg { transform: translateX(4px); }

      /* Large display text used on home */
      .v2-display {
        font-family: var(--font-display);
        font-size: clamp(3rem, 8vw, 7rem);
        line-height: 0.9;
        letter-spacing: -0.03em;
        color: var(--color-charcoal-dark);
      }

      /* Image placeholder */
      .v2-img-placeholder {
        background: var(--color-charcoal-dark);
        position: relative;
        overflow: hidden;
      }
      .v2-img-placeholder::after {
        content: '';
        position: absolute;
        inset: 0;
        opacity: 0.06;
        background-image:
          repeating-linear-gradient(
            0deg,
            transparent,
            transparent 29px,
            rgba(232,97,26,0.4) 29px,
            rgba(232,97,26,0.4) 30px
          ),
          repeating-linear-gradient(
            90deg,
            transparent,
            transparent 29px,
            rgba(232,97,26,0.4) 29px,
            rgba(232,97,26,0.4) 30px
          );
      }

      /* Stat block */
      .v2-stat {
        text-align: center;
        padding: 2rem 1rem;
      }
      .v2-stat__num {
        font-family: var(--font-display);
        font-size: 3.5rem;
        line-height: 1;
        color: var(--color-ember);
      }
      .v2-stat__label {
        font-family: var(--font-heading);
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--color-slate);
        margin-top: 0.5rem;
      }
    </style>
  </body>
</html>
